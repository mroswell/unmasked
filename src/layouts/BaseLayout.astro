---
import '../styles/global.css';
import SearchBox from '../components/SearchBox.astro';
import GlossaryTooltips from '../components/GlossaryTooltips.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Unmasked: a structured presentation of the Senate PSI report and its underlying records.' } = Astro.props;

// Active-page detection. Astro.url.pathname includes the deploy base prefix
// (e.g., '/unmasked/timeline/' on github.io); strip it to compare against
// the literal hrefs in the nav.
const base = import.meta.env.BASE_URL;
const stripBase = (p: string) => (p.startsWith(base) ? '/' + p.slice(base.length) : p);
const route = stripBase(Astro.url.pathname);
const isActive = (href: string) =>
  href === '/' ? route === '/' : route === href || route.startsWith(href);

const navLinks = [
  { href: '/explainer/', label: 'Explainer' },
  { href: '/timeline/', label: 'Timeline' },
  { href: '/documents/', label: 'Documents' },
  { href: '/quotes/', label: 'Quotes' },
  { href: '/people/', label: 'People' },
  { href: '/glossary/', label: 'Glossary' },
  { href: '/about/', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">Unmasked</a>
      <nav>
        {navLinks.map(({ href, label }) => (
          <a href={href} aria-current={isActive(href) ? 'page' : undefined}>{label}</a>
        ))}
      </nav>
      <div class="search-mount" data-pagefind-ignore>
        <SearchBox />
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Source: <a href="https://www.hsgac.senate.gov/">U.S. Senate Permanent Subcommittee on Investigations</a> hearing materials. This site is not affiliated with the Subcommittee.</p>
    </footer>
    <GlossaryTooltips />
  </body>
</html>
