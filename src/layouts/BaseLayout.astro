---
import '../styles/global.css';
import SearchBox from '../components/SearchBox.astro';
import GlossaryTooltips from '../components/GlossaryTooltips.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Vaccine Safety Signals: a structured, footnoted presentation of the Senate PSI report and its underlying records.' } = Astro.props;

// Active-page detection. Astro.url.pathname includes the deploy base prefix
// (e.g., '/unmasked/timeline/' on github.io); strip it to compare against
// the route component of the nav hrefs.
const base = import.meta.env.BASE_URL;
const stripBase = (p: string) => (p.startsWith(base) ? '/' + p.slice(base.length) : p);
const route = stripBase(Astro.url.pathname);
const isActive = (path: string) =>
  path === '/' ? route === '/' : route === path || route.startsWith(path);

// Base-prefix hand-written hrefs at render time so navigation works in dev too,
// without depending on the post-build path rewriter.
const link = (path: string) => base + path.replace(/^\//, '');

const navLinks = [
  { path: '/explainer/', label: 'Explainer' },
  { path: '/timeline/',  label: 'Timeline' },
  { path: '/documents/', label: 'Documents' },
  { path: '/quotes/',    label: 'Quotes' },
  { path: '/people/',    label: 'People' },
  { path: '/glossary/',  label: 'Glossary' },
  { path: '/about/',     label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <a href={base} class="site-title">Vaccine Safety Signals</a>
      <button
        class="nav-toggle"
        type="button"
        aria-label="Menu"
        aria-controls="primary-nav"
        aria-expanded="false"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
          <line class="nav-toggle-line nav-toggle-top" x1="4" y1="7" x2="20" y2="7"/>
          <line class="nav-toggle-line nav-toggle-mid" x1="4" y1="12" x2="20" y2="12"/>
          <line class="nav-toggle-line nav-toggle-bot" x1="4" y1="17" x2="20" y2="17"/>
        </svg>
      </button>
      <nav id="primary-nav">
        {navLinks.map(({ path, label }) => (
          <a href={link(path)} aria-current={isActive(path) ? 'page' : undefined}>{label}</a>
        ))}
      </nav>
      <div class="search-mount" data-pagefind-ignore>
        <SearchBox />
      </div>
    </header>

    <script is:inline>
      // Toggle the mobile nav. Below 860px the nav is hidden until the
      // hamburger is tapped; the toggle flips both aria-expanded and a
      // body-level class the CSS keys off of.
      (function() {
        const btn = document.querySelector('.nav-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const open = document.body.classList.toggle('nav-open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
        // Close after navigating to a link (mostly relevant when the new
        // page is the same single-page-app-style scroll, e.g. /timeline/#date).
        document.querySelectorAll('#primary-nav a').forEach((a) => {
          a.addEventListener('click', () => {
            document.body.classList.remove('nav-open');
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      })();
    </script>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Source: <a href="https://www.hsgac.senate.gov/">U.S. Senate Permanent Subcommittee on Investigations</a> hearing materials. This site is not affiliated with the Subcommittee.</p>
    </footer>
    <GlossaryTooltips />
  </body>
</html>
