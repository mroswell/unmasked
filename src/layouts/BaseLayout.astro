---
import '../styles/global.css';
import SearchBox from '../components/SearchBox.astro';
import GlossaryTooltips from '../components/GlossaryTooltips.astro';
import ShareButtons from '../components/ShareButtons.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Vaccine Safety Signals: a structured, footnoted presentation of the Senate PSI report and its underlying records.' } = Astro.props;

// Full URL of the current page, used in OpenGraph + Twitter Card meta tags
// and passed to ShareButtons so each network gets the right URL embedded.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
// 1200x630 is the recommended OpenGraph image ratio (1.91:1). The
// 1407x768 original is preserved at /og-img.jpg as a backup; the
// active preview is the cropped/resized + background-whitened
// derivative (the source had a slight cream cast in the bg).
const ogImageUrl = new URL('/og-img-1200x630-white.jpg', Astro.site).href;

// Active-page detection. Astro.url.pathname includes the deploy base prefix
// (e.g., '/unmasked/timeline/' on github.io); strip it to compare against
// the route component of the nav hrefs.
const base = import.meta.env.BASE_URL;
const stripBase = (p: string) => (p.startsWith(base) ? '/' + p.slice(base.length) : p);
const route = stripBase(Astro.url.pathname);
const isActive = (path: string) =>
  path === '/' ? route === '/' : route === path || route.startsWith(path);

// Base-prefix hand-written hrefs at render time so navigation works in dev too,
// without depending on the post-build path rewriter.
const link = (path: string) => base + path.replace(/^\//, '');

const navLinks = [
  { path: '/',           label: 'Home' },
  { path: '/explainer/', label: 'Explainer' },
  { path: '/timeline/',  label: 'Timeline' },
  { path: '/documents/', label: 'Documents' },
  { path: '/quotes/',    label: 'Quotes' },
  { path: '/people/',    label: 'People' },
  { path: '/glossary/',  label: 'Glossary' },
  { path: '/about/',     label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Favicons. Files live in public/ (served at site root). Multiple sizes
        cover browser tab (16/32 PNG + .ico fallback for very old browsers),
        iOS home screen (180 apple-touch), and Android / PWA install (192,
        512 via the manifest). theme-color tints the browser chrome on
        Android Chrome / Edge / Brave. */}
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}favicon-16x16.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />
    <meta name="theme-color" content="#0f4c5c" />

    {/* OpenGraph (Facebook, LinkedIn, BlueSky, iMessage previews, etc.) */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Vaccine Safety Signals" />

    {/* Twitter / X cards */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Google Analytics 4 (gtag.js). Standard install — async tag-loader
        plus the inline init. The measurement ID is the project's
        production ID; if you ever rotate property IDs, edit it here. */}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-255FPTN6M8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-255FPTN6M8');
    </script>
    {/* Critical layout CSS, inlined so it applies on first paint — before
        any external stylesheet finishes loading. Without this, the new
        page can render briefly with default flex behavior (nav left-
        aligned), then snap to centered once global.css applies, which
        reads as a "menu flash" leftward on every navigation. */}
    <style is:inline>
      /* Desktop layout (>1024px): 3-column grid keeps the nav locked
         in column 2 regardless of search-mount width or scrollbar. */
      .site-header {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        font-family: Inter, system-ui, -apple-system, sans-serif;
        padding: 0.7rem 1.5rem;
        border-bottom: 1px solid #d8d8d8;
        background: #fafafa;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .site-header > nav { grid-column: 2; display: flex; gap: 0.25rem; }
      .site-header > .search-mount {
        grid-column: 3;
        justify-self: end;
        width: 14rem;
      }
      .site-header > .nav-toggle { display: none; }
      /* Brand logo sits at the right edge of column 1 — i.e. just to
         the left of the centered nav (whose first link is "Home"). */
      .site-header > .site-logo {
        grid-column: 1;
        justify-self: end;
        display: inline-flex;
        align-items: center;
        padding: 0.2rem;
        border-radius: 6px;
        text-decoration: none;
      }
      .site-header > .site-logo img { display: block; width: 32px; height: 32px; }

      /* Mobile layout (≤1024px): flex with wrap, hamburger + drawer.
         These rules MUST live in the same inline block as the desktop
         rules — otherwise the global stylesheet's @media block can't
         override the higher-specificity inline `.site-header > …`
         selectors and the hamburger stays hidden on narrow viewports. */
      @media (max-width: 1024px) {
        .site-header {
          display: flex;
          flex-wrap: wrap;
          padding: 0.6rem 1rem;
          gap: 0.5rem;
        }
        .site-header > .site-logo {
          order: 1;
          grid-column: auto;
          justify-self: auto;
        }
        .site-header > .nav-toggle {
          display: inline-flex;
          order: 2;
          margin-left: auto;
        }
        .site-header > .search-mount {
          order: 3;
          width: auto;
          flex: 1 1 100%;
          min-width: 0;
          margin-top: 0.4rem;
          grid-column: auto;
          justify-self: auto;
        }
        .site-header > nav {
          order: 4;
          width: 100%;
          grid-column: auto;
          flex-direction: column;
          gap: 0.1rem;
          padding-top: 0.4rem;
          border-top: 1px solid #d8d8d8;
          margin-top: 0.4rem;
          display: none;
        }
        body.nav-open .site-header > nav { display: flex; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <a class="site-logo" href={link('/')} aria-label="Vaccine Safety Signals home">
        <img src={`${base}android-chrome-512x512.png`} alt="" width="32" height="32" />
      </a>
      <button
        class="nav-toggle"
        type="button"
        aria-label="Menu"
        aria-controls="primary-nav"
        aria-expanded="false"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
          <line class="nav-toggle-line nav-toggle-top" x1="4" y1="7" x2="20" y2="7"/>
          <line class="nav-toggle-line nav-toggle-mid" x1="4" y1="12" x2="20" y2="12"/>
          <line class="nav-toggle-line nav-toggle-bot" x1="4" y1="17" x2="20" y2="17"/>
        </svg>
      </button>
      <nav id="primary-nav">
        {navLinks.map(({ path, label }) => (
          <a href={link(path)} aria-current={isActive(path) ? 'page' : undefined}>{label}</a>
        ))}
      </nav>
      <div class="search-mount" data-pagefind-ignore>
        <SearchBox />
      </div>
    </header>

    <script is:inline>
      // Toggle the mobile nav. Below 860px the nav is hidden until the
      // hamburger is tapped; the toggle flips both aria-expanded and a
      // body-level class the CSS keys off of.
      (function() {
        const btn = document.querySelector('.nav-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const open = document.body.classList.toggle('nav-open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
        // Close after navigating to a link (mostly relevant when the new
        // page is the same single-page-app-style scroll, e.g. /timeline/#date).
        document.querySelectorAll('#primary-nav a').forEach((a) => {
          a.addEventListener('click', () => {
            document.body.classList.remove('nav-open');
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      })();
    </script>
    <main>
      <slot />
      <ShareButtons title={title} />
    </main>
    <footer class="site-footer">
      <p>Source: <a href="https://www.hsgac.senate.gov/">U.S. Senate Permanent Subcommittee on Investigations</a> hearing <a href="https://www.hsgac.senate.gov/subcommittees/investigations/hearings/unmasked-how-biden-health-officials-purposely-turned-a-blind-eye-toward-covid-19-vaccine-safety-signals/">materials</a>. This site is not affiliated with the Subcommittee.</p>
    </footer>
    <GlossaryTooltips />
  </body>
</html>
