---
import '../styles/global.css';
import SearchBox from '../components/SearchBox.astro';
import GlossaryTooltips from '../components/GlossaryTooltips.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Vaccine Safety Signals: pharmacovigilance, on the record. A structured, footnoted presentation of the Senate PSI report and its underlying records.' } = Astro.props;

// Active-page detection. Astro.url.pathname includes the deploy base prefix
// (e.g., '/unmasked/timeline/' on github.io); strip it to compare against
// the route component of the nav hrefs.
const base = import.meta.env.BASE_URL;
const stripBase = (p: string) => (p.startsWith(base) ? '/' + p.slice(base.length) : p);
const route = stripBase(Astro.url.pathname);
const isActive = (path: string) =>
  path === '/' ? route === '/' : route === path || route.startsWith(path);

// Base-prefix hand-written hrefs at render time so navigation works in dev too,
// without depending on the post-build path rewriter.
const link = (path: string) => base + path.replace(/^\//, '');

const navLinks = [
  { path: '/explainer/', label: 'Explainer' },
  { path: '/timeline/',  label: 'Timeline' },
  { path: '/documents/', label: 'Documents' },
  { path: '/quotes/',    label: 'Quotes' },
  { path: '/people/',    label: 'People' },
  { path: '/glossary/',  label: 'Glossary' },
  { path: '/about/',     label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <a href={base} class="site-title">Vaccine Safety Signals</a>
      <nav>
        {navLinks.map(({ path, label }) => (
          <a href={link(path)} aria-current={isActive(path) ? 'page' : undefined}>{label}</a>
        ))}
      </nav>
      <div class="search-mount" data-pagefind-ignore>
        <SearchBox />
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Source: <a href="https://www.hsgac.senate.gov/">U.S. Senate Permanent Subcommittee on Investigations</a> hearing materials. This site is not affiliated with the Subcommittee.</p>
    </footer>
    <GlossaryTooltips />
  </body>
</html>
