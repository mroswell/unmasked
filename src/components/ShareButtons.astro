---
// Per-page share row. Sits between main and footer in BaseLayout.
// Generates click-through URLs for the major networks at build time using
// Astro.url.pathname + Astro.site, plus a copy-link button (clipboard API)
// and a mailto: link.
//
// Icons: inline SVG (Simple Icons paths for the brand marks; Lucide-style
// strokes for the neutral copy/email icons). Monochrome at rest, hover
// transitions to the platform's brand color.

interface Props {
  title: string;
}
const { title } = Astro.props;

const fullUrl = new URL(Astro.url.pathname, Astro.site).href;
const enc = encodeURIComponent;

const shareLinks = [
  {
    brand: 'x',
    label: 'Share on X',
    href: `https://twitter.com/intent/tweet?url=${enc(fullUrl)}&text=${enc(title)}`,
    svg: '<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644Z"/>',
  },
  {
    brand: 'bluesky',
    label: 'Share on BlueSky',
    href: `https://bsky.app/intent/compose?text=${enc(title + ' ' + fullUrl)}`,
    svg: '<path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"/>',
  },
  {
    brand: 'linkedin',
    label: 'Share on LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(fullUrl)}`,
    svg: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/>',
  },
  {
    brand: 'facebook',
    label: 'Share on Facebook',
    href: `https://www.facebook.com/sharer/sharer.php?u=${enc(fullUrl)}`,
    svg: '<path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"/>',
  },
  {
    brand: 'email',
    label: 'Share by email',
    href: `mailto:?subject=${enc(title)}&body=${enc(fullUrl)}`,
    svg: '<g fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></g>',
  },
];
---

<div class="share-buttons" aria-label="Share this page">
  <span class="share-label">Share:</span>
  {shareLinks.map((s) => (
    <a
      href={s.href}
      data-brand={s.brand}
      target={s.brand === 'email' ? undefined : '_blank'}
      rel={s.brand === 'email' ? undefined : 'noopener noreferrer'}
      aria-label={s.label}
      title={s.label}
    >
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" set:html={s.svg}></svg>
    </a>
  ))}
  <button type="button" class="share-copy" data-url={fullUrl} aria-label="Copy link" title="Copy link">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
      <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
    </svg>
  </button>
</div>

<script is:inline>
  // Copy-to-clipboard via the navigator API; fall back to a hidden textarea
  // for older browsers (and browsers that block clipboard.writeText on
  // file:// or non-secure contexts).
  document.querySelectorAll('.share-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      let copied = false;
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(url);
          copied = true;
        }
      } catch (_) { /* fall through to fallback */ }
      if (!copied) {
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { copied = document.execCommand('copy'); } catch (_) {}
        document.body.removeChild(ta);
      }
      const original = btn.getAttribute('title') || 'Copy link';
      btn.setAttribute('title', copied ? 'Copied!' : 'Copy failed');
      btn.classList.add(copied ? 'is-copied' : 'is-error');
      setTimeout(() => {
        btn.setAttribute('title', original);
        btn.classList.remove('is-copied', 'is-error');
      }, 1500);
    });
  });
</script>

<style>
  .share-buttons {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 0;
    margin-top: 2rem;
    border-top: 1px solid var(--color-border-soft);
    color: var(--color-muted);
    font-family: var(--font-sans);
  }
  .share-label {
    font-size: 0.85rem;
    margin-right: 0.4rem;
  }
  .share-buttons a,
  .share-buttons button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--color-muted);
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .share-buttons a:hover,
  .share-buttons button:hover {
    background: rgba(15, 76, 92, 0.06);
  }
  /* Per-platform brand-color hover. Restraint by default; the tint only
     comes through when the user is hovering an icon. */
  .share-buttons a[data-brand="x"]:hover         { color: #000; }
  .share-buttons a[data-brand="bluesky"]:hover   { color: #0085ff; }
  .share-buttons a[data-brand="linkedin"]:hover  { color: #0a66c2; }
  .share-buttons a[data-brand="facebook"]:hover  { color: #1877f2; }
  .share-buttons a[data-brand="email"]:hover     { color: var(--color-accent); }
  .share-buttons button:hover                    { color: var(--color-accent); }
  .share-buttons button.is-copied                { color: #15803d; }
  .share-buttons button.is-error                 { color: #b41e1e; }

  .share-buttons svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
</style>
