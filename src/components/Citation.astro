---
import { getEntry } from 'astro:content';
import { findBatesPage } from '../lib/bates-page-lookup.ts';
import { cleanFootnoteText } from '../lib/clean-footnote-text.ts';

interface Props {
  citationId: string;
}

const { citationId } = Astro.props;
const citation = await getEntry('citations', citationId);
const popoverId = `popover-${citationId}`;
const base = import.meta.env.BASE_URL;

// Link rendering: a footnote can point to multiple sources at once (e.g.
// a primary Bates email AND a "See also" external testimony URL). The
// renderer surfaces every link the citation has — document_id, bundle
// deep-link, and external_url are not mutually exclusive. Earlier
// versions used else-if, which silently dropped external_url whenever
// bates_ids resolved. Mirror this in remark-citations.ts.
const docHref = citation?.data.document_id
  ? `${base}documents/${citation.data.document_id}/`
  : null;
const bundleHit = !docHref && citation ? findBatesPage(citation.data.bates_ids) : null;
const externalUrl = citation?.data.external_url ?? null;
const hasAnyLink = Boolean(docHref || bundleHit || externalUrl);
// External link is the "primary" affordance only when nothing else
// rendered; otherwise it's a "See also" supplementary pointer.
const externalIsPrimary = !docHref && !bundleHit;
// Strip the external URL from the displayed prose since the same URL
// is one of the clickable links below — no need to duplicate it as
// plain text in the popover body.
const citeText = citation ? cleanFootnoteText(citation.data.footnote_text, externalUrl) : '';
---

{citation && (
  <>
    <button
      type="button"
      popovertarget={popoverId}
      class="cite-marker"
      id={`fn-marker-${citationId}`}
    >
      [{citationId.replace(/^fn-/, '')}]
    </button>
    <div popover="auto" id={popoverId} class="cite-popover">
      {citeText && <p class="cite-text">{citeText}</p>}
      {citation.data.bates_ids && citation.data.bates_ids.length > 0 && (
        <span class="cite-bates">{citation.data.bates_ids.join('; ')}</span>
      )}
      {docHref && <a href={docHref} class="cite-link">Read document →</a>}
      {bundleHit && (
        <>
          <a href={`${base}documents/${bundleHit.bundleId}/#doc-page-${bundleHit.page}`} class="cite-link">Read PDF (page {bundleHit.page}) →</a>
          <a href={`${base}documents/${bundleHit.bundleId}/#text-page-${bundleHit.page}`} class="cite-link cite-link--secondary">View as text →</a>
        </>
      )}
      {externalUrl && (
        <a
          href={externalUrl}
          class={externalIsPrimary ? 'cite-link' : 'cite-link cite-link--secondary'}
          target="_blank"
          rel="noopener"
        >
          {externalIsPrimary ? 'External source →' : 'See also: external source →'}
        </a>
      )}
      {!hasAnyLink && (
        <span class="cite-link cite-link--unavailable">Document not publicly posted</span>
      )}
    </div>
  </>
)}

<!-- Citation marker + popover styles live in src/styles/global.css so the
     same classes apply to remark-emitted citations inside markdown bodies. -->
