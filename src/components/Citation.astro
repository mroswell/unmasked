---
import { getEntry } from 'astro:content';

interface Props {
  citationId: string;
}

const { citationId } = Astro.props;
const citation = await getEntry('citations', citationId);
const popoverId = `popover-${citationId}`;

let linkLabel: string;
let linkHref: string | null = null;
if (citation?.data.document_id) {
  linkLabel = 'Read document →';
  linkHref = `/documents/${citation.data.document_id}/`;
} else if (citation?.data.external_url) {
  linkLabel = 'External source →';
  linkHref = citation.data.external_url;
} else {
  linkLabel = 'Document not publicly posted';
}
---

{citation && (
  <>
    <button
      type="button"
      popovertarget={popoverId}
      class="cite-marker"
      id={`fn-marker-${citationId}`}
    >
      [{citationId.replace(/^fn-/, '')}]
    </button>
    <div popover="auto" id={popoverId} class="cite-popover">
      <p class="cite-text">{citation.data.footnote_text}</p>
      {linkHref ? (
        <a href={linkHref} class="cite-link">{linkLabel}</a>
      ) : (
        <span class="cite-link cite-link--unavailable">{linkLabel}</span>
      )}
    </div>
  </>
)}

<style>
  .cite-marker {
    display: inline-block;
    background: none;
    border: none;
    color: var(--color-accent);
    font-family: var(--font-sans);
    font-size: 0.75em;
    cursor: pointer;
    padding: 0;
    vertical-align: super;
  }
  .cite-popover {
    max-width: 22rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    background: white;
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }
  .cite-text { margin: 0 0 0.6rem; }
  .cite-link { font-weight: 600; }
  .cite-link--unavailable { color: var(--color-muted); font-weight: 400; }
</style>
