---
import { getEntry } from 'astro:content';
import { findBatesPage } from '../lib/bates-page-lookup.ts';

interface Props {
  citationId: string;
}

const { citationId } = Astro.props;
const citation = await getEntry('citations', citationId);
const popoverId = `popover-${citationId}`;
const base = import.meta.env.BASE_URL;

// Priority mirrors remark-citations.ts:
//   standalone document_id → bundle deep-link → external_url → unavailable.
type LinkVariant =
  | { kind: 'doc'; href: string }
  | { kind: 'bundle'; pdfHref: string; textHref: string; page: number }
  | { kind: 'external'; href: string }
  | { kind: 'unavailable' };

let link: LinkVariant = { kind: 'unavailable' };
if (citation?.data.document_id) {
  link = { kind: 'doc', href: `${base}documents/${citation.data.document_id}/` };
} else if (citation) {
  const hit = findBatesPage(citation.data.bates_ids);
  if (hit) {
    link = {
      kind: 'bundle',
      pdfHref: `${base}documents/${hit.bundleId}/#doc-page-${hit.page}`,
      textHref: `${base}documents/${hit.bundleId}/#text-page-${hit.page}`,
      page: hit.page,
    };
  } else if (citation.data.external_url) {
    link = { kind: 'external', href: citation.data.external_url };
  }
}
---

{citation && (
  <>
    <button
      type="button"
      popovertarget={popoverId}
      class="cite-marker"
      id={`fn-marker-${citationId}`}
    >
      [{citationId.replace(/^fn-/, '')}]
    </button>
    <div popover="auto" id={popoverId} class="cite-popover">
      <p class="cite-text">{citation.data.footnote_text}</p>
      {citation.data.bates_ids && citation.data.bates_ids.length > 0 && (
        <span class="cite-bates">{citation.data.bates_ids.join('; ')}</span>
      )}
      {link.kind === 'doc' && <a href={link.href} class="cite-link">Read document →</a>}
      {link.kind === 'bundle' && (
        <>
          <a href={link.pdfHref} class="cite-link">Read PDF (page {link.page}) →</a>
          <a href={link.textHref} class="cite-link cite-link--secondary">View as text →</a>
        </>
      )}
      {link.kind === 'external' && (
        <a href={link.href} class="cite-link" target="_blank" rel="noopener">External source →</a>
      )}
      {link.kind === 'unavailable' && (
        <span class="cite-link cite-link--unavailable">Document not publicly posted</span>
      )}
    </div>
  </>
)}

<!-- Citation marker + popover styles live in src/styles/global.css so the
     same classes apply to remark-emitted citations inside markdown bodies. -->
