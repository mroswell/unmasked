---
// This component injects the glossary tooltip script + handles
// tooltip enrichment for both server-rendered <dfn> elements
// (from the remark plugin) and plain-text terms on .astro pages.
const base = import.meta.env.BASE_URL;
---

<script is:inline define:vars={{ base }}>
  (async function() {
    try {
      const [aliasesResp, defsResp] = await Promise.all([
        fetch(base + 'glossary-aliases.json'),
        fetch(base + 'glossary-shortdefs.json'),
      ]);
      if (!aliasesResp.ok || !defsResp.ok) return;
      const aliases = await aliasesResp.json();
      const defs = await defsResp.json();

      // Singleton tooltip rendered in <body>, positioned with JS on
      // hover/focus. Because the element lives outside all overflow
      // ancestors, the tooltip can't be clipped by .doc-text-pre or
      // any other scrollable container — which is the whole reason we
      // moved away from CSS-pseudo-element tooltips.
      const tooltipEl = document.createElement('div');
      tooltipEl.className = 'glossary-tooltip';
      tooltipEl.setAttribute('role', 'tooltip');
      tooltipEl.style.cssText = 'display:none;position:fixed;z-index:10000;pointer-events:auto;';
      document.body.appendChild(tooltipEl);

      let activeDfn = null;
      let hideTimer = 0;

      function position(dfn) {
        // Display first so we can measure (then maybe reposition).
        tooltipEl.style.display = 'block';
        tooltipEl.classList.remove('glossary-tooltip--below');
        const dfnRect = dfn.getBoundingClientRect();
        const tRect = tooltipEl.getBoundingClientRect();
        const pad = 8;
        // Centered horizontally on the dfn, but kept inside the viewport.
        let left = dfnRect.left + dfnRect.width / 2 - tRect.width / 2;
        left = Math.max(pad, Math.min(left, window.innerWidth - tRect.width - pad));
        let top = dfnRect.top - tRect.height - 10;
        if (top < pad) {
          // Not enough room above — flip below the dfn.
          top = dfnRect.bottom + 10;
          tooltipEl.classList.add('glossary-tooltip--below');
        }
        tooltipEl.style.left = left + 'px';
        tooltipEl.style.top = top + 'px';
      }

      function show(dfn, text) {
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = 0; }
        activeDfn = dfn;
        tooltipEl.textContent = text;
        position(dfn);
      }

      function scheduleHide() {
        if (hideTimer) clearTimeout(hideTimer);
        hideTimer = window.setTimeout(() => {
          tooltipEl.style.display = 'none';
          activeDfn = null;
          hideTimer = 0;
        }, 120);
      }

      tooltipEl.addEventListener('mouseenter', () => {
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = 0; }
      });
      tooltipEl.addEventListener('mouseleave', scheduleHide);

      // If anything in the page scrolls (including nested overflow
      // containers like .doc-text-pre), dismiss — the tooltip is
      // position:fixed so it'd otherwise float detached from its dfn.
      window.addEventListener('scroll', () => {
        if (activeDfn) {
          tooltipEl.style.display = 'none';
          activeDfn = null;
          if (hideTimer) { clearTimeout(hideTimer); hideTimer = 0; }
        }
      }, { passive: true, capture: true });

      function enhanceDfn(el, text) {
        if (!text || el.dataset.glossaryBound === '1') return;
        el.dataset.glossaryBound = '1';
        el.setAttribute('data-tooltip', text);
        if (!el.hasAttribute('tabindex')) el.setAttribute('tabindex', '0');
        el.addEventListener('mouseenter', () => show(el, text));
        el.addEventListener('mouseleave', scheduleHide);
        el.addEventListener('focus', () => show(el, text));
        el.addEventListener('blur', scheduleHide);
      }

      // Step 1: enhance existing <dfn> elements (from remark-glossary).
      document.querySelectorAll('dfn[data-term]').forEach((el) => {
        const term = el.getAttribute('data-term');
        if (term && defs[term]) enhanceDfn(el, defs[term]);
      });

      // Step 2: wrap plain-text glossary terms inside main content blocks
      // that don't already have <dfn> markup (i.e., .astro pages).
      const wrappedCanonicals = new Set();
      // Mark any canonical that already has a <dfn> on the page so we
      // don't double-wrap.
      document.querySelectorAll('dfn[data-term]').forEach((el) => {
        const t = el.getAttribute('data-term');
        if (t) wrappedCanonicals.add(t);
      });

      const sortedAliases = aliases.slice().sort((a, b) => b.alias.length - a.alias.length);

      const scopes = document.querySelectorAll('main article, main .prose-page, main .prose');
      scopes.forEach((scope) => {
        // Walk text nodes; replace the first occurrence of each unwrapped canonical.
        const walker = document.createTreeWalker(scope, NodeFilter.SHOW_TEXT, {
          acceptNode: (n) => {
            if (!n.parentElement) return NodeFilter.FILTER_REJECT;
            // Skip if inside <code>, <pre>, <dfn>, <a>, or [data-no-gloss]
            for (let p = n.parentElement; p && p !== scope; p = p.parentElement) {
              const tag = p.tagName;
              if (tag === 'CODE' || tag === 'PRE' || tag === 'DFN' || tag === 'A') return NodeFilter.FILTER_REJECT;
              if (p.hasAttribute('data-no-gloss')) return NodeFilter.FILTER_REJECT;
            }
            return NodeFilter.FILTER_ACCEPT;
          },
        });
        const candidates = [];
        let node;
        while ((node = walker.nextNode())) candidates.push(node);

        for (const textNode of candidates) {
          let value = textNode.nodeValue || '';
          let bestIndex = Infinity, best = null;
          for (const { canonical, alias } of sortedAliases) {
            if (wrappedCanonicals.has(canonical)) continue;
            const re = new RegExp('\\b' + alias.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '\\b', 'i');
            const m = value.match(re);
            if (m && m.index !== undefined) {
              if (m.index < bestIndex) {
                bestIndex = m.index;
                best = { canonical, matched: m[0], at: m.index };
              }
            }
          }
          if (!best) continue;

          const before = value.slice(0, best.at);
          const after = value.slice(best.at + best.matched.length);
          const beforeNode = before ? document.createTextNode(before) : null;
          const dfn = document.createElement('dfn');
          dfn.setAttribute('data-term', best.canonical);
          dfn.textContent = best.matched;
          const afterNode = after ? document.createTextNode(after) : null;

          const parent = textNode.parentNode;
          if (!parent) continue;
          if (beforeNode) parent.insertBefore(beforeNode, textNode);
          parent.insertBefore(dfn, textNode);
          if (afterNode) parent.insertBefore(afterNode, textNode);
          parent.removeChild(textNode);

          if (defs[best.canonical]) enhanceDfn(dfn, defs[best.canonical]);
          wrappedCanonicals.add(best.canonical);
        }
      });
    } catch (e) {
      // Silently ignore — search and tooltips degrade to plain text.
    }
  })();
</script>
