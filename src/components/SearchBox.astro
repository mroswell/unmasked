<div id="pagefind-search-mount"></div>
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<script is:inline>
  import('/pagefind/pagefind-ui.js').then(({ PagefindUI }) => {
    new PagefindUI({
      element: '#pagefind-search-mount',
      showImages: false,
      showSubResults: true,
      excerptLength: 30,
    });
  }).catch(() => {
    // Pagefind index isn't available (dev server or stale preview).
    // Hide the search affordance entirely rather than show a confusing placeholder.
    const mount = document.getElementById('pagefind-search-mount');
    const wrapper = mount?.closest('.search-mount');
    if (wrapper instanceof HTMLElement) wrapper.style.display = 'none';
  });
</script>
