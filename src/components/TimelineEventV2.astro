---
import type { CollectionEntry } from 'astro:content';
import Citation from './Citation.astro';
import { renderMarkdownToHtml } from '../lib/render-markdown.ts';

interface Props {
  event: CollectionEntry<'timelineV2'>;
}

const { event } = Astro.props;
const html = await renderMarkdownToHtml(event.data.body);

const CATEGORY_LABELS: Record<string, string> = {
  regulatory: 'REGULATORY',
  analysis: 'ANALYSIS',
  internal: 'INTERNAL',
  publication: 'PUBLICATION',
  oversight: 'OVERSIGHT',
};
---

<article class={`timeline-event timeline-event--${event.data.category}`} id={event.data.date} data-pagefind-body>
  <header class="event-header">
    <span class="event-category">{CATEGORY_LABELS[event.data.category]}</span>
    <span class="event-sep">·</span>
    <time class="event-date" datetime={event.data.date}>{event.data.date_display}</time>
  </header>
  <p class="event-summary">{event.data.summary}</p>
  <div class="event-body" set:html={html}></div>
  {event.data.citations.length > 0 && (
    <div class="event-citations">
      <strong>Citations:</strong>
      {event.data.citations.map((id) => <Citation citationId={id} />)}
    </div>
  )}
</article>

<style>
  .timeline-event {
    position: relative;
    padding: 0 0 2rem 2rem;
    margin: 0;
  }

  .timeline-event::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 0.4rem;
    width: 14px;
    height: 14px;
    background: var(--cat-color, var(--color-accent));
    border-radius: 50%;
    border: 3px solid var(--color-bg);
    z-index: 1;
  }

  .timeline-event--regulatory  { --cat-color: #3a6b8c; }
  .timeline-event--analysis    { --cat-color: #0f4c5c; }
  .timeline-event--internal    { --cat-color: #806b52; }
  .timeline-event--publication { --cat-color: #6b7a3a; }
  .timeline-event--oversight   { --cat-color: #6b3a5a; }

  .event-header {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    margin-bottom: 0.4rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
  }

  .event-category {
    color: var(--cat-color, var(--color-accent));
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .event-sep {
    color: var(--color-muted);
  }

  .event-date {
    color: var(--color-muted);
    font-weight: 500;
  }

  .event-summary {
    font-weight: 700;
    margin: 0.2rem 0 0.6rem;
    font-size: 1.05rem;
    line-height: 1.4;
  }

  .event-body {
    font-size: 0.97rem;
    line-height: 1.65;
  }

  .event-body :global(p) { margin: 0.6rem 0; }
  .event-body :global(p:first-child) { margin-top: 0; }
  .event-body :global(blockquote) {
    border-left: 3px solid var(--cat-color, var(--color-accent));
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-muted);
    font-style: italic;
  }
  .event-body :global(ul), .event-body :global(ol) {
    margin: 0.6rem 0;
    padding-left: 1.5rem;
  }

  .event-citations {
    margin-top: 0.8rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  @media print {
    .timeline-event { page-break-inside: avoid; }
  }
</style>
