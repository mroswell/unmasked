---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineEventV2 from '../../components/TimelineEventV2.astro';

const events = (await getCollection('timelineV2')).sort((a, b) => a.data.date.localeCompare(b.data.date));
---

<BaseLayout title="Timeline (redesign) — Signals">
  <div class="version-banner">
    <strong>Redesigned timeline.</strong> Categorized events, vertical-rail layout, always-expanded.
    <a href="/timeline/">Compare with original →</a>
  </div>
  <h1>Timeline</h1>
  <p class="lede">Records released by the U.S. Senate Permanent Subcommittee on Investigations chronicle FDA scientists' attempts to surface masking-affected safety signals in COVID-19 vaccine adverse event data, and the agency's responses.</p>
  <div class="legend">
    <span class="legend-item legend-item--regulatory"><span class="dot"></span>Regulatory action</span>
    <span class="legend-item legend-item--analysis"><span class="dot"></span>Scientific analysis</span>
    <span class="legend-item legend-item--internal"><span class="dot"></span>Internal conversation</span>
    <span class="legend-item legend-item--publication"><span class="dot"></span>Publication</span>
    <span class="legend-item legend-item--oversight"><span class="dot"></span>Oversight</span>
  </div>
  <div class="timeline-rail">
    {events.map((event) => <TimelineEventV2 event={event} />)}
  </div>
</BaseLayout>

<style>
  .version-banner {
    background: #fff8e8;
    border: 1px solid #e8d394;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .version-banner a { margin-left: 1rem; }

  .lede { color: var(--color-muted); max-width: var(--max-prose); }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    margin: 1.5rem 0 2rem;
    color: var(--color-muted);
  }
  .legend-item { display: flex; align-items: center; gap: 0.4rem; }
  .legend-item .dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
  .legend-item--regulatory  .dot { background: #3a6b8c; }
  .legend-item--analysis    .dot { background: #0f4c5c; }
  .legend-item--internal    .dot { background: #806b52; }
  .legend-item--publication .dot { background: #6b7a3a; }
  .legend-item--oversight   .dot { background: #6b3a5a; }

  .timeline-rail {
    position: relative;
    margin-left: 0.5rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--color-border);
  }
</style>
