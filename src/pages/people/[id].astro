---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
  actor: {
    id: string;
    name: string;
    role_at_time: string;
    short_bio: string;
  };
}

export async function getStaticPaths() {
  const actors = await getCollection('actors');
  return actors.map((a) => ({
    params: { id: a.data.id },
    props: { actor: a.data },
  }));
}

const { actor } = Astro.props;

const events = (await getCollection('timeline'))
  .filter((e) => e.data.actors.includes(actor.id))
  .sort((a, b) => a.data.date.localeCompare(b.data.date));

const quotes = (await getCollection('quotes')).filter(
  (q) => q.data.speaker === actor.id
);

// Surface this person's hearing testimony + any "supporting document"
// they filed under the same id prefix (e.g. wiseman → wiseman-testimony,
// wiseman-supporting-document-1, wiseman-supporting-document-2). Sort
// pins the main testimony to the top, then orders supporting docs
// alphabetically so `-1` precedes `-2`.
const testimonyDocs = (await getCollection('documents'))
  .filter(
    (d) =>
      d.data.doc_type === 'testimony' &&
      (d.data.bates_id === `${actor.id}-testimony` ||
        d.data.bates_id.startsWith(`${actor.id}-supporting-`)),
  )
  .sort((a, b) => {
    const aMain = a.data.bates_id === `${actor.id}-testimony`;
    const bMain = b.data.bates_id === `${actor.id}-testimony`;
    if (aMain !== bMain) return aMain ? -1 : 1;
    return a.data.bates_id.localeCompare(b.data.bates_id);
  });

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${actor.name} — Unmasked`}>
  <article class="person-page" data-pagefind-body data-pagefind-filter="content-type:Person">
    <header>
      <h1>{actor.name}</h1>
      <p class="role">{actor.role_at_time}</p>
      <p class="bio">{actor.short_bio}</p>
    </header>

    <p class="back-link">
      <a href={`${base}people/`}>← All people</a>
    </p>

    {testimonyDocs.length > 0 && (
      <section>
        <h2>
          Hearing testimony
          {testimonyDocs.length > 1 && <span class="count">({testimonyDocs.length})</span>}
        </h2>
        <ul class="testimony-list">
          {testimonyDocs.map((doc) => {
            const isMain = doc.data.bates_id === `${actor.id}-testimony`;
            return (
              <li>
                <a href={`${base}documents/${doc.data.bates_id}/`} class="testimony-link">
                  <span class="testimony-label">{isMain ? 'Written testimony' : 'Supporting document'}</span>
                  <span class="testimony-title">{doc.data.title}</span>
                  {doc.data.page_count != null && (
                    <span class="testimony-pages">{doc.data.page_count} {doc.data.page_count === 1 ? 'page' : 'pages'}</span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {events.length > 0 ? (
      <section>
        <h2>
          Timeline appearances
          <span class="count">({events.length})</span>
        </h2>
        <ul class="event-list">
          {events.map((event) => (
            <li>
              <a href={`${base}timeline/#${event.data.date}`} class="event-link">
                <time datetime={event.data.date}>{event.data.date_display}</time>
                <span class={`event-cat event-cat--${event.data.category}`}>
                  {event.data.category}
                </span>
              </a>
              <p class="event-summary">{event.data.summary}</p>
            </li>
          ))}
        </ul>
      </section>
    ) : (
      <section>
        <h2>Timeline appearances</h2>
        <p class="empty">No timeline events reference this person.</p>
      </section>
    )}

    {quotes.length > 0 && (
      <section>
        <h2>
          Quotes
          <span class="count">({quotes.length})</span>
        </h2>
        <ul class="quote-list">
          {quotes.map((q) => (
            <li>
              <blockquote>
                "{q.data.text}"
                <footer class="quote-context">
                  <span class="context">{q.data.context}</span>
                  {q.data.date && <span class="date"> · {q.data.date}</span>}
                  {' '}
                  <a href={`${base}quotes/#${q.data.id}`} class="quote-anchor">view in /quotes/ →</a>
                </footer>
              </blockquote>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .person-page header { margin-bottom: 1.5rem; max-width: var(--max-prose); }
  .person-page h1 { margin: 0 0 0.3rem; }
  .role {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.8rem;
  }
  .bio { margin: 0; max-width: var(--max-prose); }

  .back-link {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    margin: 0 0 2rem;
  }
  .back-link a { color: var(--color-muted); text-decoration: none; }
  .back-link a:hover { color: var(--color-accent); }

  .person-page section { margin-bottom: 2.5rem; max-width: var(--max-prose); }
  .person-page h2 {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.4rem;
    margin-bottom: 1rem;
  }
  .count {
    color: var(--color-muted);
    font-weight: 400;
    font-size: 0.9em;
    margin-left: 0.4rem;
  }

  .event-list, .quote-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .event-list li {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .event-list li:last-child { border-bottom: none; }

  .event-link {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .event-link time {
    font-weight: 600;
    color: var(--color-accent);
    min-width: 8rem;
  }
  .event-link:hover time { text-decoration: underline; }

  .event-cat {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    color: white;
  }
  .event-cat--regulatory  { background: #1e40af; }
  .event-cat--analysis    { background: #0f4c5c; }
  .event-cat--internal    { background: #b45309; }
  .event-cat--publication { background: #15803d; }
  .event-cat--oversight   { background: #6b21a8; }

  .event-summary {
    margin: 0.3rem 0 0 8.75rem;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  @media (max-width: 540px) {
    .event-link { flex-direction: column; gap: 0.25rem; }
    .event-summary { margin-left: 0; }
  }

  .quote-list blockquote {
    margin: 0;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 6px 6px 0;
    font-size: 1rem;
  }
  .quote-context {
    margin-top: 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--color-muted);
  }
  .quote-anchor {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }
  .quote-anchor:hover { text-decoration: underline; }

  .empty {
    color: var(--color-muted);
    font-style: italic;
  }

  .testimony-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .testimony-link {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 0.85rem;
    padding: 0.7rem 1rem;
    background: white;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 6px 6px 0;
    text-decoration: none;
    color: var(--color-text);
    font-family: var(--font-sans);
  }
  .testimony-link:hover {
    border-color: var(--color-accent);
    background: rgba(15, 76, 92, 0.03);
  }
  .testimony-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .testimony-title {
    flex: 1 1 auto;
    font-size: 0.95rem;
    font-weight: 500;
  }
  .testimony-pages {
    font-size: 0.8rem;
    color: var(--color-muted);
  }
</style>
