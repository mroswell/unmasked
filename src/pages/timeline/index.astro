---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineEvent from '../../components/TimelineEvent.astro';

const events = (await getCollection('timeline')).sort((a, b) => a.data.date.localeCompare(b.data.date));
---

<BaseLayout title="Timeline — Signals">
  <h1>Timeline</h1>
  <p class="lede">Records released by the U.S. Senate Permanent Subcommittee on Investigations chronicle FDA scientists' attempts to surface masking-affected safety signals in COVID-19 vaccine adverse event data, and the agency's responses.</p>
  <div class="legend">
    <span class="legend-item legend-item--regulatory"><span class="dot"></span>Regulatory action</span>
    <span class="legend-item legend-item--analysis"><span class="dot"></span>Scientific analysis</span>
    <span class="legend-item legend-item--internal"><span class="dot"></span>Internal conversation</span>
    <span class="legend-item legend-item--publication"><span class="dot"></span>Publication</span>
    <span class="legend-item legend-item--oversight"><span class="dot"></span>Oversight</span>
  </div>
  <div class="timeline-rail">
    {events.map((event) => <TimelineEvent event={event} />)}
  </div>
</BaseLayout>

<style>
  .lede { color: var(--color-muted); max-width: var(--max-prose); }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    margin: 1.5rem 0 2rem;
    color: var(--color-muted);
  }
  .legend-item { display: flex; align-items: center; gap: 0.4rem; }
  .legend-item .dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
  .legend-item--regulatory  .dot { background: #1e40af; }
  .legend-item--analysis    .dot { background: #0f4c5c; }
  .legend-item--internal    .dot { background: #b45309; }
  .legend-item--publication .dot { background: #15803d; }
  .legend-item--oversight   .dot { background: #6b21a8; }

  .timeline-rail {
    position: relative;
    margin-left: 0.5rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--color-border);
  }
</style>
