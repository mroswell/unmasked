---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineEvent from '../../components/TimelineEvent.astro';

const events = (await getCollection('timeline')).sort((a, b) => a.data.date.localeCompare(b.data.date));
---

<BaseLayout title="Timeline — Vaccine Safety Signals">
  <h1>Timeline</h1>
  <p class="lede">Records released by the U.S. Senate Permanent Subcommittee on Investigations chronicle FDA scientists' attempts to surface masking-affected safety signals in COVID-19 vaccine adverse event data, the agency's responses, and the Subcommittee's oversight.</p>

  <div class="filters" role="region" aria-label="Filter timeline">
    <div class="filter-row">
      <label class="search-label">
        <span class="visually-hidden">Search timeline</span>
        <input
          type="search"
          id="timeline-search"
          class="search-input"
          placeholder="Search events (e.g. Szarfman, myocarditis, March 2021)…"
          autocomplete="off"
        />
      </label>
    </div>
    <div class="filter-row">
      <span class="filter-label">Source</span>
      <button class="filter-chip is-active" data-filter="source" data-value="all" type="button">All</button>
      <button class="filter-chip" data-filter="source" data-value="report-body" type="button">Section II (FDA story)</button>
      <button class="filter-chip" data-filter="source" data-value="report-appendix" type="button">Appendix (PSI oversight)</button>
    </div>
    <div class="filter-row">
      <span class="filter-label">Category</span>
      <button class="filter-chip is-active" data-filter="category" data-value="all" type="button">All</button>
      <button class="filter-chip filter-chip--regulatory" data-filter="category" data-value="regulatory" type="button"><span class="dot"></span>Regulatory</button>
      <button class="filter-chip filter-chip--analysis" data-filter="category" data-value="analysis" type="button"><span class="dot"></span>Analysis</button>
      <button class="filter-chip filter-chip--internal" data-filter="category" data-value="internal" type="button"><span class="dot"></span>Internal</button>
      <button class="filter-chip filter-chip--publication" data-filter="category" data-value="publication" type="button"><span class="dot"></span>Publication</button>
      <button class="filter-chip filter-chip--oversight" data-filter="category" data-value="oversight" type="button"><span class="dot"></span>Oversight</button>
    </div>
  </div>

  <p class="empty-state" hidden>No events match the current filters.</p>

  <div class="timeline-rail">
    {events.map((event) => <TimelineEvent event={event} />)}
  </div>
</BaseLayout>

<script>
  const state: { source: string; category: string; q: string } = { source: 'all', category: 'all', q: '' };
  const events = document.querySelectorAll('.timeline-event');
  const emptyState = document.querySelector('.empty-state');
  const searchInput = document.getElementById('timeline-search') as HTMLInputElement | null;

  function applyFilters() {
    const q = state.q.toLowerCase().trim();
    let visibleCount = 0;
    events.forEach((el) => {
      const ev = el as HTMLElement;
      const src = ev.dataset.source;
      const cat = ev.dataset.category;
      const text = ev.dataset.searchText ?? '';
      const sourceOk = state.source === 'all' || state.source === src;
      const categoryOk = state.category === 'all' || state.category === cat;
      const queryOk = q === '' || text.includes(q);
      const visible = sourceOk && categoryOk && queryOk;
      ev.hidden = !visible;
      if (visible) visibleCount++;
    });
    if (emptyState) (emptyState as HTMLElement).hidden = visibleCount > 0;
  }

  document.querySelectorAll<HTMLButtonElement>('.filter-chip').forEach((btn) => {
    btn.addEventListener('click', () => {
      const dim = btn.dataset.filter as 'source' | 'category';
      const val = btn.dataset.value!;
      state[dim] = val;
      document.querySelectorAll<HTMLElement>(`.filter-chip[data-filter="${dim}"]`).forEach((b) => {
        b.classList.toggle('is-active', b.dataset.value === val);
      });
      applyFilters();
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      state.q = searchInput.value;
      applyFilters();
    });
  }

  // When the user arrives via a global-search result (URL like
  // /timeline/?q=szarfman#2021-03-26), pre-populate the search input
  // and apply the filter so the timeline opens already narrowed to
  // matching events. Re-scroll to the hash anchor afterwards in case
  // the filter changed layout above it.
  const initialQ = new URLSearchParams(window.location.search).get('q');
  if (initialQ && searchInput) {
    searchInput.value = initialQ;
    state.q = initialQ;
    applyFilters();
    if (window.location.hash) {
      const target = document.querySelector(window.location.hash);
      if (target instanceof HTMLElement && !target.hidden) {
        requestAnimationFrame(() => target.scrollIntoView({ block: 'start' }));
      }
    }
  }
</script>

<style>
  .lede { color: var(--color-muted); max-width: var(--max-prose); }

  .filters {
    margin: 2rem 0 2.5rem;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .filter-row + .filter-row { margin-top: 0.6rem; }
  .search-label { flex: 1; }
  .search-input {
    width: 100%;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .search-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .filter-label {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    color: var(--color-muted);
    width: 4.5rem;
    flex-shrink: 0;
  }
  .filter-chip {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-family: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .filter-chip:hover { border-color: var(--color-accent); }
  .filter-chip.is-active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }
  .filter-chip .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--chip-color, var(--color-accent));
  }
  .filter-chip--regulatory  { --chip-color: #1e40af; }
  .filter-chip--analysis    { --chip-color: #0f4c5c; }
  .filter-chip--internal    { --chip-color: #b45309; }
  .filter-chip--publication { --chip-color: #15803d; }
  .filter-chip--oversight   { --chip-color: #6b21a8; }

  .empty-state {
    color: var(--color-muted);
    font-style: italic;
    margin: 2rem 0;
  }

  .timeline-rail {
    position: relative;
    margin-left: 0.5rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--color-border);
  }
</style>
