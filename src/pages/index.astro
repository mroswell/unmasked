---
import BaseLayout from '../layouts/BaseLayout.astro';
import { runBuildValidation } from '../lib/build-validate';

await runBuildValidation();
---

<BaseLayout title="Unmasked — Vaccine Safety Signal Masking">
  <section class="hero">
    <h1>Unmasked</h1>
    <p class="lede">A structured presentation of the U.S. Senate Permanent Subcommittee on Investigations' April 2026 interim report and the underlying records published with it. The site centers the evidence: contemporaneous emails, the masking phenomenon in VAERS data mining, and the MGPS / RGPS comparison that drives the story.</p>
  </section>
  <section class="modes">
    <a class="mode" href="/explainer/">
      <h2>Explainer</h2>
      <p>What is signal masking? Plain-language walkthrough for non-experts.</p>
    </a>
    <a class="mode" href="/timeline/">
      <h2>Timeline</h2>
      <p>Dated chronology, November 2020 to today, with citations and source documents.</p>
    </a>
    <a class="mode" href="/documents/">
      <h2>Document archive</h2>
      <p>Searchable record of every Subcommittee-published exhibit.</p>
    </a>
  </section>
</BaseLayout>

<style>
  .hero { max-width: var(--max-prose); margin: 2rem auto; }
  .hero h1 { font-size: 3rem; margin: 0 0 0.5em; }
  .lede { font-size: 1.15rem; color: var(--color-muted); }
  .modes { display: grid; grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr)); gap: 1.5rem; margin-top: 3rem; }
  .mode { display: block; padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 6px; text-decoration: none; color: var(--color-text); background: white; }
  .mode:hover { border-color: var(--color-accent); }
  .mode h2 { margin: 0 0 0.5rem; font-family: var(--font-sans); font-size: 1.25rem; color: var(--color-accent); }
  .mode p { margin: 0; font-size: 0.95rem; }
</style>
