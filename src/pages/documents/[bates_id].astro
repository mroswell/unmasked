---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';

interface Props {
  doc: CollectionEntry<'documents'>;
}

export async function getStaticPaths() {
  const docs = await getCollection('documents');
  return docs.map((doc) => ({ params: { bates_id: doc.data.bates_id }, props: { doc } }));
}

const { doc } = Astro.props;

let textContent = '';
if (doc.data.ocr_text_path) {
  try {
    textContent = await readFile(join('./public', doc.data.ocr_text_path), 'utf-8');
  } catch {
    /* sidecar may not exist for some docs */
  }
}

// For bundled PDFs (anything with a sibling -pages.json from
// scripts/build-bates-page-index.mjs), build a server-side HTML string
// for the text tab, with per-page heading markers so deep-links like
// #text-page-23 can scroll to the right page AND Pagefind's auto
// sub-result splitting (which keys on headings) produces per-page
// search-result URLs. Page markers are <h2> rather than <a> for that
// reason; the visual styling is overridden via .doc-text-page-marker.
let pagedTextHtml: string | null = null;
try {
  const pagesPath = join('./public/documents', `${doc.data.bates_id}-pages.json`);
  const raw = await readFile(pagesPath, 'utf-8');
  const parsed = JSON.parse(raw) as { totalPages: number; pages: string[] };
  if (Array.isArray(parsed.pages) && parsed.pages.length > 0) {
    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const total = parsed.pages.length;
    pagedTextHtml = parsed.pages
      .map(
        (page, i) =>
          `<h2 id="text-page-${i + 1}" class="doc-text-page-marker">— Page ${i + 1} of ${total} —</h2>\n${escape(page)}\n\n`,
      )
      .join('');
  }
} catch {
  /* no per-page sidecar — render flat */
}

// Load table JSON for spreadsheets
type SpreadsheetData = { sheets: { name: string; headers: string[]; rows: string[][] }[] };
let table: SpreadsheetData | null = null;
if (doc.data.format === 'spreadsheet' && doc.data.table_data_path) {
  try {
    const raw = await readFile(join('./public', doc.data.table_data_path), 'utf-8');
    table = JSON.parse(raw);
  } catch {}
}

// For very large sheets, cap row rendering and link to download for the full table.
const MAX_ROWS_PER_SHEET = 1000;
let truncated = false;
const renderedSheets = table
  ? table.sheets.map((s) => {
      if (s.rows.length > MAX_ROWS_PER_SHEET) {
        truncated = true;
        return { ...s, rows: s.rows.slice(0, MAX_ROWS_PER_SHEET), totalRows: s.rows.length };
      }
      return { ...s, totalRows: s.rows.length };
    })
  : null;

// Asset paths in the document JSON are root-relative (e.g. "/documents/foo.pdf");
// prefix with the deploy base so they resolve in dev too, not only after the
// post-build rewriter runs in prod.
const base = import.meta.env.BASE_URL;
const baseAsset = (p: string | undefined | null): string | null =>
  p ? base.replace(/\/$/, '') + p : null;

const pdfHref = baseAsset(doc.data.pdf_path);
const xlsxHref = baseAsset(doc.data.xlsx_path);
const downloadHref = doc.data.format === 'spreadsheet' ? xlsxHref : pdfHref;
const downloadLabel = doc.data.format === 'spreadsheet' ? 'Original spreadsheet' : 'PDF';
const isPdf = doc.data.format === 'pdf';
---

<BaseLayout title={`${doc.data.title} — Vaccine Safety Signals`}>
  <article class="document-page" data-pagefind-body data-pagefind-filter="content-type:Document">
    <header>
      <h1>{doc.data.title}</h1>
      <p class="bates"><code>{doc.data.bates_id}</code></p>
    </header>

    <dl class="doc-meta-bar">
      <div>
        <dt>Type</dt>
        <dd class="type-meta">
          <span class={`format-badge format-${doc.data.format}`}>
            {doc.data.format === 'spreadsheet' ? 'Spreadsheet' : 'PDF'}
          </span>
          {doc.data.format === 'pdf' && (
            <span class="doc-type-suffix">({doc.data.doc_type[0].toUpperCase() + doc.data.doc_type.slice(1)})</span>
          )}
        </dd>
      </div>
      {doc.data.date && <div><dt>Date</dt><dd>{doc.data.date}</dd></div>}
      {doc.data.page_count != null && <div><dt>Pages</dt><dd>{doc.data.page_count}</dd></div>}
      <div><dt>Source</dt><dd><a href={doc.data.source_url}>hsgac.senate.gov</a></dd></div>
      {downloadHref && <div><dt>Download</dt><dd><a href={downloadHref}>{downloadLabel}</a></dd></div>}
    </dl>

    {isPdf && (
      <div class="doc-tabs-wrap">
        <div class="doc-tabs" role="tablist" aria-label="Document views">
          <button role="tab" id="tab-doc" aria-controls="panel-doc" aria-selected="true" type="button" data-tab="doc">Document (PDF)</button>
          <button role="tab" id="tab-text" aria-controls="panel-text" aria-selected="false" type="button" data-tab="text" tabindex="-1">
            Document (Text)
          </button>
          <div class="doc-text-controls" aria-label="Text size controls">
            <button class="text-size-btn" data-action="text-smaller" type="button" aria-label="Smaller text" title="Smaller text">A−</button>
            <button class="text-size-btn" data-action="text-larger" type="button" aria-label="Larger text" title="Larger text">A+</button>
            <button class="text-size-btn text-size-btn--reset" data-action="text-reset" type="button" aria-label="Reset text size to default" title="Reset text size to default">Reset</button>
          </div>
        </div>

        <div id="panel-doc" role="tabpanel" aria-labelledby="tab-doc" class="tab-panel">
          <div class="pdf-pane">
            {/* Two design constraints intersect here:
                  (1) A dynamic src change AFTER the browser starts loading
                      the PDF can leave Chrome's viewer in a stuck state,
                      so when the user arrives on the doc tab we set src
                      ONCE with the right #page=N fragment baked in.
                  (2) But when the user arrives on the text tab (e.g. via
                      a Pagefind search hit at #text-page-N), panel-doc
                      becomes display:none milliseconds after the embed
                      starts loading — Chrome treats that as a navigation
                      away and aborts the fetch, leaving the viewer blank
                      when the user later switches in.
                Resolution: set src only if the initial hash is on the doc
                tab. Otherwise leave src unset; activate('doc') will
                populate it on demand when the user clicks Document, at
                which point the panel is visible and the load can proceed. */}
            <embed type="application/pdf" data-pdf-base={pdfHref!} />
            <script is:inline define:vars={{ pdfHref }}>
              (function() {
                var e = document.currentScript.previousElementSibling;
                if (!e || !pdfHref) return;
                var hash = (location.hash || '').slice(1);
                var docMatch = hash.match(/^doc(?:-page-(\d+))?$/);
                if (docMatch) {
                  e.setAttribute('src', docMatch[1] ? pdfHref + '#page=' + docMatch[1] : pdfHref);
                }
              })();
            </script>
            <p class="pdf-fallback">If the PDF doesn't load, <a href={doc.data.source_url}>view the original on hsgac.senate.gov</a>.</p>
          </div>
        </div>

        <div id="panel-text" role="tabpanel" aria-labelledby="tab-text" class="tab-panel" hidden>
          {pagedTextHtml ? (
            /* <div> not <pre> here: the paged HTML contains <h2> page
               markers (block elements), which aren't valid phrasing
               content for <pre>. CSS's white-space: pre-wrap preserves
               the same visual whitespace handling. */
            <div class="doc-text-pre" set:html={pagedTextHtml}></div>
          ) : textContent.trim().length >= 50 ? (
            <pre class="doc-text-pre">{textContent}</pre>
          ) : (
            <p class="empty-text-note">No extractable text was detected in this document. The original PDF is available above.</p>
          )}
        </div>
      </div>
    )}

    {!isPdf && renderedSheets && (
      <div class="spreadsheet-pane">
        {truncated && (
          <p class="truncation-note">
            This spreadsheet is large; only the first {MAX_ROWS_PER_SHEET.toLocaleString()} rows of each sheet are shown.
            {xlsxHref && (<> <a href={xlsxHref}>Download the full file</a> for complete data.</>)}
          </p>
        )}
        {renderedSheets.map((sheet) => (
          <div class="sheet">
            {renderedSheets.length > 1 && <h2 class="sheet-name">{sheet.name}</h2>}
            <p class="sheet-meta">
              {sheet.totalRows.toLocaleString()} row{sheet.totalRows === 1 ? '' : 's'}
              {sheet.totalRows > sheet.rows.length && (<> (showing first {sheet.rows.length.toLocaleString()})</>)}
            </p>
            <div class="table-wrap">
              <table>
                {sheet.headers.length > 0 && (
                  <thead>
                    <tr>{sheet.headers.map((h) => <th>{h}</th>)}</tr>
                  </thead>
                )}
                <tbody>
                  {sheet.rows.map((row) => (
                    <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
        {textContent && (
          <details class="doc-text-details">
            <summary>Plain text view</summary>
            <pre class="doc-text-pre">{textContent}</pre>
          </details>
        )}
      </div>
    )}
  </article>
</BaseLayout>

<script>
  // Hash-routed tabs with optional `-page-N` deep-link.
  // Examples: `#doc`, `#text`, `#doc-page-23`, `#text-page-23`.
  const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
  const panels = document.querySelectorAll<HTMLElement>('.tab-panel');
  const embed = document.querySelector<HTMLEmbedElement>('.pdf-pane embed');
  const pdfBase = embed?.dataset.pdfBase ?? '';

  function parseHash(raw: string): { tab: 'doc' | 'text'; page: number | null } {
    const m = raw.match(/^(doc|text)(?:-page-(\d+))?$/);
    return {
      tab: (m?.[1] as 'doc' | 'text') ?? 'doc',
      page: m?.[2] ? parseInt(m[2], 10) : null,
    };
  }

  function activate(rawName: string) {
    const { tab, page } = parseHash(rawName);
    tabs.forEach((t) => {
      const active = t.dataset.tab === tab;
      t.setAttribute('aria-selected', active ? 'true' : 'false');
      t.tabIndex = active ? 0 : -1;
    });
    panels.forEach((p) => {
      p.hidden = !p.id.endsWith(`-${tab}`);
    });
    // Text-size controls live in the tabs row but only apply to the
    // Text panel; hide them entirely on the PDF tab.
    document.querySelectorAll<HTMLElement>('.doc-text-controls').forEach((el) => {
      el.hidden = tab !== 'text';
    });

    if (tab === 'doc' && embed && pdfBase) {
      // PDF Open Parameters — supported by Chrome/Edge/Firefox/Safari built-in viewers.
      const desired = page ? `${pdfBase}#page=${page}` : pdfBase;
      if (embed.getAttribute('src') !== desired) embed.setAttribute('src', desired);
    } else if (tab === 'text' && page) {
      const target = document.getElementById(`text-page-${page}`);
      // Wait one frame so panel.hidden=false has applied before scrolling.
      requestAnimationFrame(() => target?.scrollIntoView({ block: 'start' }));
    }
  }

  // Preserve `-page-N` across in-page tab clicks: clicking "Document" while
  // viewing #text-page-23 should swap to #doc-page-23, not lose the page.
  function currentPageSuffix(): string {
    const m = window.location.hash.slice(1).match(/-page-(\d+)$/);
    return m ? `-page-${m[1]}` : '';
  }

  if (tabs.length) {
    activate((window.location.hash || '#doc').slice(1));
    tabs.forEach((t) => {
      t.addEventListener('click', () => {
        const next = `${t.dataset.tab!}${currentPageSuffix()}`;
        activate(next);
        history.replaceState(null, '', `#${next}`);
      });
    });
    window.addEventListener('hashchange', () => activate(window.location.hash.slice(1)));
  }

  // Text-size controls (A− / A+) for the Document (Text) panel. The
  // chosen size is stored in localStorage, so it carries across
  // navigations between document pages.
  const TEXT_SIZES = [0.75, 0.85, 0.95, 1.05, 1.20, 1.40];
  const DEFAULT_SIZE_IDX = 1;
  const SIZE_STORAGE_KEY = 'doc-text-size-idx';
  const smallerBtns = document.querySelectorAll<HTMLButtonElement>('[data-action="text-smaller"]');
  const largerBtns = document.querySelectorAll<HTMLButtonElement>('[data-action="text-larger"]');
  const resetBtns = document.querySelectorAll<HTMLButtonElement>('[data-action="text-reset"]');

  function applyTextSizeIdx(idx: number): number {
    const clamped = Math.max(0, Math.min(TEXT_SIZES.length - 1, idx));
    document.documentElement.style.setProperty('--doc-text-font-size', TEXT_SIZES[clamped] + 'rem');
    try { localStorage.setItem(SIZE_STORAGE_KEY, String(clamped)); } catch {}
    smallerBtns.forEach((b) => { b.disabled = clamped <= 0; });
    largerBtns.forEach((b) => { b.disabled = clamped >= TEXT_SIZES.length - 1; });
    resetBtns.forEach((b) => { b.disabled = clamped === DEFAULT_SIZE_IDX; });
    return clamped;
  }

  let currentSizeIdx = DEFAULT_SIZE_IDX;
  try {
    const stored = localStorage.getItem(SIZE_STORAGE_KEY);
    if (stored !== null) {
      const n = parseInt(stored, 10);
      if (Number.isInteger(n)) currentSizeIdx = n;
    }
  } catch {}
  currentSizeIdx = applyTextSizeIdx(currentSizeIdx);

  smallerBtns.forEach((btn) => {
    btn.addEventListener('click', () => { currentSizeIdx = applyTextSizeIdx(currentSizeIdx - 1); });
  });
  largerBtns.forEach((btn) => {
    btn.addEventListener('click', () => { currentSizeIdx = applyTextSizeIdx(currentSizeIdx + 1); });
  });
  resetBtns.forEach((btn) => {
    btn.addEventListener('click', () => { currentSizeIdx = applyTextSizeIdx(DEFAULT_SIZE_IDX); });
  });
</script>

<style>
  .document-page header { margin-bottom: 1rem; }
  .bates { font-family: var(--font-sans); color: var(--color-muted); margin-top: -0.5rem; }

  .doc-meta-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    margin: 1rem 0 1.5rem;
    padding: 0.75rem 1rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }
  .doc-meta-bar div { display: flex; gap: 0.4rem; align-items: baseline; }
  .doc-meta-bar dt {
    font-weight: 600;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.72rem;
    margin: 0;
  }
  .doc-meta-bar dd { margin: 0; }
  .doc-meta-bar .type-meta { display: inline-flex; gap: 0.4rem; align-items: baseline; }
  .doc-type-suffix { color: var(--color-muted); font-size: 0.85rem; }

  .format-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .format-pdf {
    background: rgba(180, 30, 30, 0.1);
    color: #b41e1e;
    border: 1px solid rgba(180, 30, 30, 0.3);
  }
  .format-spreadsheet {
    background: rgba(30, 130, 70, 0.1);
    color: #1e8246;
    border: 1px solid rgba(30, 130, 70, 0.3);
  }

  .doc-tabs {
    display: flex;
    gap: 0.4rem;
    border-bottom: 2px solid var(--color-input-border);
    margin-bottom: 0;
    /* Stick the tabs just below the site header so a user who arrives
       on #text-page-23 (via a Pagefind search hit, for example) can
       always toggle back to the Document tab without scrolling up. */
    position: sticky;
    top: 3.4rem;
    z-index: 90;
    background: var(--color-bg);
    padding-top: 0.4rem;
  }
  /* Inactive tab: visible 1px border so the tab reads as a clickable
     control (the previous transparent border made tabs nearly
     invisible until hover). Active tab: 2px accent-colored top
     border + sides; the bottom border is masked white so the tab
     visually merges with the panel below. */
  .doc-tabs button[role="tab"] {
    background: var(--color-bg);
    border: 1px solid var(--color-input-border);
    border-bottom: none;
    padding: 0.55rem 1.15rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-muted);
    cursor: pointer;
    border-radius: 6px 6px 0 0;
    margin-bottom: -2px;
    position: relative;
  }
  .doc-tabs button[role="tab"]:hover {
    color: var(--color-accent);
    background: white;
  }
  .doc-tabs button[role="tab"][aria-selected="true"] {
    color: var(--color-accent);
    background: white;
    border-color: var(--color-accent);
    border-width: 2px 2px 0 2px;
    padding: calc(0.55rem - 1px) calc(1.15rem - 1px);
  }
  /* Cover the doc-tabs' bottom border under the active tab so it
     visually connects to the panel rather than being divided from it. */
  .doc-tabs button[role="tab"][aria-selected="true"]::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: white;
  }

  .pdf-pane embed { width: 100%; height: 80vh; border: 1px solid var(--color-border); }
  .pdf-fallback { font-size: 0.9rem; color: var(--color-muted); margin-top: 0.5rem; }

  .empty-text-note {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }
  /* Text-size controls (A− / A+ / Reset) live in the tabs row so
     they don't consume vertical space above the text content.
     Right-aligned via margin-left:auto, vertically centered with
     the tabs via align-self:center. Hidden on the PDF tab. */
  .doc-text-controls {
    margin-left: auto;
    align-self: center;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .text-size-btn {
    background: white;
    border: 1px solid var(--color-input-border);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.8rem;
    line-height: 1.2;
    min-width: 2rem;
    text-align: center;
  }
  .text-size-btn--reset {
    min-width: 0;
    font-weight: 500;
    color: var(--color-muted);
  }
  .text-size-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .text-size-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .doc-text-pre {
    background: white;
    border: 1px solid var(--color-border);
    /* No top border — the doc-tabs' grey border-bottom serves as the
       visual top edge of the text container, so the doc-text-pre's
       own white padding-top is the only thing between the tabs and
       the scrolling text. */
    border-top: 0;
    padding: 1rem;
    font-family: var(--font-sans);
    /* Font size driven by --doc-text-font-size, set inline on
       document.documentElement by the A−/A+ controls. Persisted in
       localStorage so the user's preferred size carries across
       document pages. */
    font-size: var(--doc-text-font-size, 0.85rem);
    line-height: 1.5;
    max-height: 70vh;
    overflow: auto;
    white-space: pre-wrap;
    /* offset for sticky header so #text-page-N anchors land below it */
    scroll-padding-top: 1rem;
    /* Pin the text frame just below the sticky tabs. Without this,
       page-scrolling slides the frame up under the tabs, and the
       white padding-top eventually scrolls behind them — leaving
       the text visually touching the tab border. With sticky, the
       frame stays and the 1rem of white padding-top is always
       visible between the tabs and the scrolling text. */
    position: sticky;
    top: 6rem;
  }
  /* .doc-text-page-marker lives in src/styles/global.css — it styles an
     element injected via set:html, which doesn't pick up Astro's scoped
     data-astro-cid attribute, so the rule must be global to apply. */
  .doc-text-details { margin-top: 1.5rem; }

  /* Spreadsheet styles unchanged */
  .spreadsheet-pane .sheet + .sheet { margin-top: 2rem; }
  .sheet-name { font-family: var(--font-sans); font-size: 1.1rem; font-weight: 600; margin: 0 0 0.25rem; }
  .sheet-meta { font-family: var(--font-sans); font-size: 0.85rem; color: var(--color-muted); margin: 0 0 0.5rem; }
  .truncation-note { font-family: var(--font-sans); font-size: 0.9rem; padding: 0.5rem 0.75rem; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 4px; margin-bottom: 1rem; }
  .table-wrap { overflow-x: auto; max-height: 70vh; overflow-y: auto; border: 1px solid var(--color-border); }
  .spreadsheet-pane table { border-collapse: collapse; font-family: var(--font-sans); font-size: 0.85rem; min-width: 100%; }
  .spreadsheet-pane th, .spreadsheet-pane td { padding: 0.4rem 0.6rem; border-bottom: 1px solid var(--color-border); border-right: 1px solid var(--color-border); text-align: left; vertical-align: top; }
  .spreadsheet-pane th { background: var(--color-bg); font-weight: 600; position: sticky; top: 0; }
  .spreadsheet-pane tr:nth-child(even) td { background: rgba(0,0,0,0.02); }

  /* ------- Mobile ------- */
  @media (max-width: 640px) {
    .doc-meta-bar { gap: 0.4rem 1rem; padding: 0.6rem 0.75rem; font-size: 0.85rem; }
    .pdf-pane embed { height: 65vh; }
    .doc-tabs button[role="tab"] {
      padding: 0.5rem 0.75rem;
      font-size: 0.9rem;
      flex: 1;
      text-align: center;
    }
    .doc-text-pre { font-size: 0.8rem; padding: 0.7rem; }
    .spreadsheet-pane th, .spreadsheet-pane td { padding: 0.35rem 0.45rem; font-size: 0.8rem; }
  }
</style>
