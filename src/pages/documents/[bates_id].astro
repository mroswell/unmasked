---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';

interface Props {
  doc: CollectionEntry<'documents'>;
}

export async function getStaticPaths() {
  const docs = await getCollection('documents');
  return docs.map((doc) => ({ params: { bates_id: doc.data.bates_id }, props: { doc } }));
}

const { doc } = Astro.props;

let textContent = '';
if (doc.data.ocr_text_path) {
  try {
    textContent = await readFile(join('./public', doc.data.ocr_text_path), 'utf-8');
  } catch {
    /* sidecar may not exist for some docs */
  }
}

// For bundled PDFs (anything with a sibling -pages.json from
// scripts/build-bates-page-index.mjs), build a server-side HTML string
// for the text tab, with per-page anchor IDs so deep-links like
// #text-page-23 can scroll to the right page. Built as a string (and
// injected via set:html) because JSX expressions inside <pre> behave
// inconsistently in Astro.
let pagedTextHtml: string | null = null;
try {
  const pagesPath = join('./public/documents', `${doc.data.bates_id}-pages.json`);
  const raw = await readFile(pagesPath, 'utf-8');
  const parsed = JSON.parse(raw) as { totalPages: number; pages: string[] };
  if (Array.isArray(parsed.pages) && parsed.pages.length > 0) {
    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const total = parsed.pages.length;
    pagedTextHtml = parsed.pages
      .map(
        (page, i) =>
          `<a id="text-page-${i + 1}" class="doc-text-page-marker">— Page ${i + 1} of ${total} —</a>\n${escape(page)}\n\n`,
      )
      .join('');
  }
} catch {
  /* no per-page sidecar — render flat */
}

// Load table JSON for spreadsheets
type SpreadsheetData = { sheets: { name: string; headers: string[]; rows: string[][] }[] };
let table: SpreadsheetData | null = null;
if (doc.data.format === 'spreadsheet' && doc.data.table_data_path) {
  try {
    const raw = await readFile(join('./public', doc.data.table_data_path), 'utf-8');
    table = JSON.parse(raw);
  } catch {}
}

// For very large sheets, cap row rendering and link to download for the full table.
const MAX_ROWS_PER_SHEET = 1000;
let truncated = false;
const renderedSheets = table
  ? table.sheets.map((s) => {
      if (s.rows.length > MAX_ROWS_PER_SHEET) {
        truncated = true;
        return { ...s, rows: s.rows.slice(0, MAX_ROWS_PER_SHEET), totalRows: s.rows.length };
      }
      return { ...s, totalRows: s.rows.length };
    })
  : null;

// Asset paths in the document JSON are root-relative (e.g. "/documents/foo.pdf");
// prefix with the deploy base so they resolve in dev too, not only after the
// post-build rewriter runs in prod.
const base = import.meta.env.BASE_URL;
const baseAsset = (p: string | undefined | null): string | null =>
  p ? base.replace(/\/$/, '') + p : null;

const pdfHref = baseAsset(doc.data.pdf_path);
const xlsxHref = baseAsset(doc.data.xlsx_path);
const downloadHref = doc.data.format === 'spreadsheet' ? xlsxHref : pdfHref;
const downloadLabel = doc.data.format === 'spreadsheet' ? 'Original spreadsheet' : 'PDF';
const isPdf = doc.data.format === 'pdf';
---

<BaseLayout title={`${doc.data.title} — Unmasked`}>
  <article class="document-page" data-pagefind-body data-pagefind-filter="content-type:Document">
    <header>
      <h1>{doc.data.title}</h1>
      <p class="bates"><code>{doc.data.bates_id}</code></p>
    </header>

    <dl class="doc-meta-bar">
      <div>
        <dt>Type</dt>
        <dd class="type-meta">
          <span class={`format-badge format-${doc.data.format}`}>
            {doc.data.format === 'spreadsheet' ? 'Spreadsheet' : 'PDF'}
          </span>
          {doc.data.format === 'pdf' && (
            <span class="doc-type-suffix">({doc.data.doc_type[0].toUpperCase() + doc.data.doc_type.slice(1)})</span>
          )}
        </dd>
      </div>
      {doc.data.date && <div><dt>Date</dt><dd>{doc.data.date}</dd></div>}
      {doc.data.page_count != null && <div><dt>Pages</dt><dd>{doc.data.page_count}</dd></div>}
      <div><dt>Source</dt><dd><a href={doc.data.source_url}>hsgac.senate.gov</a></dd></div>
      {downloadHref && <div><dt>Download</dt><dd><a href={downloadHref}>{downloadLabel}</a></dd></div>}
    </dl>

    {isPdf && (
      <div class="doc-tabs-wrap">
        <div class="doc-tabs" role="tablist" aria-label="Document views">
          <button role="tab" id="tab-doc" aria-controls="panel-doc" aria-selected="true" type="button" data-tab="doc">Document</button>
          <button role="tab" id="tab-text" aria-controls="panel-text" aria-selected="false" type="button" data-tab="text" tabindex="-1">
            Document text
          </button>
        </div>

        <div id="panel-doc" role="tabpanel" aria-labelledby="tab-doc" class="tab-panel">
          <div class="pdf-pane">
            {/* No `src` here on purpose: a dynamic src change after the browser
                starts loading aborts the request and can leave Chrome's PDF
                viewer in a stuck state when arriving at #doc-page-N. The
                inline script below sets src exactly once, with the right
                #page=N fragment from the URL hash already baked in. */}
            <embed type="application/pdf" data-pdf-base={pdfHref!} />
            <script is:inline define:vars={{ pdfHref }}>
              (function() {
                var e = document.currentScript.previousElementSibling;
                if (!e || !pdfHref) return;
                var m = (location.hash || '').slice(1).match(/^doc(?:-page-(\d+))?$/);
                e.setAttribute('src', m && m[1] ? pdfHref + '#page=' + m[1] : pdfHref);
              })();
            </script>
            <p class="pdf-fallback">If the PDF doesn't load, <a href={doc.data.source_url}>view the original on hsgac.senate.gov</a>.</p>
          </div>
        </div>

        <div id="panel-text" role="tabpanel" aria-labelledby="tab-text" class="tab-panel" hidden>
          {pagedTextHtml ? (
            <pre class="doc-text-pre" set:html={pagedTextHtml}></pre>
          ) : textContent.trim().length >= 50 ? (
            <pre class="doc-text-pre">{textContent}</pre>
          ) : (
            <p class="empty-text-note">No extractable text was detected in this document. The original PDF is available above.</p>
          )}
        </div>
      </div>
    )}

    {!isPdf && renderedSheets && (
      <div class="spreadsheet-pane">
        {truncated && (
          <p class="truncation-note">
            This spreadsheet is large; only the first {MAX_ROWS_PER_SHEET.toLocaleString()} rows of each sheet are shown.
            {xlsxHref && (<> <a href={xlsxHref}>Download the full file</a> for complete data.</>)}
          </p>
        )}
        {renderedSheets.map((sheet) => (
          <div class="sheet">
            {renderedSheets.length > 1 && <h2 class="sheet-name">{sheet.name}</h2>}
            <p class="sheet-meta">
              {sheet.totalRows.toLocaleString()} row{sheet.totalRows === 1 ? '' : 's'}
              {sheet.totalRows > sheet.rows.length && (<> (showing first {sheet.rows.length.toLocaleString()})</>)}
            </p>
            <div class="table-wrap">
              <table>
                {sheet.headers.length > 0 && (
                  <thead>
                    <tr>{sheet.headers.map((h) => <th>{h}</th>)}</tr>
                  </thead>
                )}
                <tbody>
                  {sheet.rows.map((row) => (
                    <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
        {textContent && (
          <details class="doc-text-details">
            <summary>Plain text view</summary>
            <pre class="doc-text-pre">{textContent}</pre>
          </details>
        )}
      </div>
    )}
  </article>
</BaseLayout>

<script>
  // Hash-routed tabs with optional `-page-N` deep-link.
  // Examples: `#doc`, `#text`, `#doc-page-23`, `#text-page-23`.
  const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
  const panels = document.querySelectorAll<HTMLElement>('.tab-panel');
  const embed = document.querySelector<HTMLEmbedElement>('.pdf-pane embed');
  const pdfBase = embed?.dataset.pdfBase ?? '';

  function parseHash(raw: string): { tab: 'doc' | 'text'; page: number | null } {
    const m = raw.match(/^(doc|text)(?:-page-(\d+))?$/);
    return {
      tab: (m?.[1] as 'doc' | 'text') ?? 'doc',
      page: m?.[2] ? parseInt(m[2], 10) : null,
    };
  }

  function activate(rawName: string) {
    const { tab, page } = parseHash(rawName);
    tabs.forEach((t) => {
      const active = t.dataset.tab === tab;
      t.setAttribute('aria-selected', active ? 'true' : 'false');
      t.tabIndex = active ? 0 : -1;
    });
    panels.forEach((p) => {
      p.hidden = !p.id.endsWith(`-${tab}`);
    });

    if (tab === 'doc' && embed && pdfBase) {
      // PDF Open Parameters — supported by Chrome/Edge/Firefox/Safari built-in viewers.
      const desired = page ? `${pdfBase}#page=${page}` : pdfBase;
      if (embed.getAttribute('src') !== desired) embed.setAttribute('src', desired);
    } else if (tab === 'text' && page) {
      const target = document.getElementById(`text-page-${page}`);
      // Wait one frame so panel.hidden=false has applied before scrolling.
      requestAnimationFrame(() => target?.scrollIntoView({ block: 'start' }));
    }
  }

  // Preserve `-page-N` across in-page tab clicks: clicking "Document" while
  // viewing #text-page-23 should swap to #doc-page-23, not lose the page.
  function currentPageSuffix(): string {
    const m = window.location.hash.slice(1).match(/-page-(\d+)$/);
    return m ? `-page-${m[1]}` : '';
  }

  if (tabs.length) {
    activate((window.location.hash || '#doc').slice(1));
    tabs.forEach((t) => {
      t.addEventListener('click', () => {
        const next = `${t.dataset.tab!}${currentPageSuffix()}`;
        activate(next);
        history.replaceState(null, '', `#${next}`);
      });
    });
    window.addEventListener('hashchange', () => activate(window.location.hash.slice(1)));
  }
</script>

<style>
  .document-page header { margin-bottom: 1rem; }
  .bates { font-family: var(--font-sans); color: var(--color-muted); margin-top: -0.5rem; }

  .doc-meta-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    margin: 1rem 0 1.5rem;
    padding: 0.75rem 1rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }
  .doc-meta-bar div { display: flex; gap: 0.4rem; align-items: baseline; }
  .doc-meta-bar dt {
    font-weight: 600;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.72rem;
    margin: 0;
  }
  .doc-meta-bar dd { margin: 0; }
  .doc-meta-bar .type-meta { display: inline-flex; gap: 0.4rem; align-items: baseline; }
  .doc-type-suffix { color: var(--color-muted); font-size: 0.85rem; }

  .format-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .format-pdf {
    background: rgba(180, 30, 30, 0.1);
    color: #b41e1e;
    border: 1px solid rgba(180, 30, 30, 0.3);
  }
  .format-spreadsheet {
    background: rgba(30, 130, 70, 0.1);
    color: #1e8246;
    border: 1px solid rgba(30, 130, 70, 0.3);
  }

  .doc-tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1rem;
  }
  .doc-tabs button[role="tab"] {
    background: transparent;
    border: 1px solid transparent;
    border-bottom: none;
    padding: 0.5rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-muted);
    cursor: pointer;
    border-radius: 4px 4px 0 0;
    margin-bottom: -1px;
  }
  .doc-tabs button[role="tab"]:hover { color: var(--color-text); }
  .doc-tabs button[role="tab"][aria-selected="true"] {
    color: var(--color-accent);
    border-color: var(--color-border);
    background: var(--color-bg);
  }
  .pdf-pane embed { width: 100%; height: 80vh; border: 1px solid var(--color-border); }
  .pdf-fallback { font-size: 0.9rem; color: var(--color-muted); margin-top: 0.5rem; }

  .empty-text-note {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }
  .doc-text-pre {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.5;
    max-height: 70vh;
    overflow: auto;
    white-space: pre-wrap;
    /* offset for sticky header so #text-page-N anchors land below it */
    scroll-padding-top: 1rem;
  }
  .doc-text-page-marker {
    display: block;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    margin: 1.25rem 0 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--color-border);
    /* extra room above so anchor scroll lands with the marker visible */
    scroll-margin-top: 4.5rem;
  }
  .doc-text-page-marker:first-child {
    margin-top: 0;
    border-top: none;
    padding-top: 0;
  }
  .doc-text-details { margin-top: 1.5rem; }

  /* Spreadsheet styles unchanged */
  .spreadsheet-pane .sheet + .sheet { margin-top: 2rem; }
  .sheet-name { font-family: var(--font-sans); font-size: 1.1rem; font-weight: 600; margin: 0 0 0.25rem; }
  .sheet-meta { font-family: var(--font-sans); font-size: 0.85rem; color: var(--color-muted); margin: 0 0 0.5rem; }
  .truncation-note { font-family: var(--font-sans); font-size: 0.9rem; padding: 0.5rem 0.75rem; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 4px; margin-bottom: 1rem; }
  .table-wrap { overflow-x: auto; max-height: 70vh; overflow-y: auto; border: 1px solid var(--color-border); }
  .spreadsheet-pane table { border-collapse: collapse; font-family: var(--font-sans); font-size: 0.85rem; min-width: 100%; }
  .spreadsheet-pane th, .spreadsheet-pane td { padding: 0.4rem 0.6rem; border-bottom: 1px solid var(--color-border); border-right: 1px solid var(--color-border); text-align: left; vertical-align: top; }
  .spreadsheet-pane th { background: var(--color-bg); font-weight: 600; position: sticky; top: 0; }
  .spreadsheet-pane tr:nth-child(even) td { background: rgba(0,0,0,0.02); }
</style>
