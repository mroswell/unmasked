---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

function capitalize(s: string) {
  return s.length ? s[0].toUpperCase() + s.slice(1) : s;
}

function formatType(d: CollectionEntry<'documents'>) {
  if (d.data.format === 'spreadsheet') return 'Spreadsheet';
  return `PDF (${capitalize(d.data.doc_type)})`;
}

// Sort primary by formatType (Type column), secondary by bates_id
const docs = (await getCollection('documents')).sort((a, b) => {
  const ftCmp = formatType(a).localeCompare(formatType(b));
  if (ftCmp !== 0) return ftCmp;
  return a.data.bates_id.localeCompare(b.data.bates_id);
});

// Build chip list dynamically from the catalog so future doc types add chips automatically
const distinctValues = Array.from(new Set(docs.map(formatType))).sort();
---

<BaseLayout title="Documents — Unmasked">
  <h1>Document archive</h1>
  <p class="archive-summary">
    {docs.length} documents from the Senate PSI investigation: testimonies, the staff report, and FOIA-produced HHS records.
  </p>

  <div class="filters" role="region" aria-label="Filter documents">
    <div class="filter-row">
      <label class="search-label">
        <span class="visually-hidden">Search documents</span>
        <input
          type="search"
          id="document-search"
          class="search-input"
          placeholder="Search documents (e.g. testimony, masking, 0008257)…"
          autocomplete="off"
        />
      </label>
    </div>
    <div class="filter-row">
      <span class="filter-label">Mode</span>
      <button class="filter-chip is-active" data-mode="filter" type="button">Filter list</button>
      <button class="filter-chip" data-mode="content" type="button">Search inside documents</button>
    </div>
    <div class="filter-row" data-mode-only="filter">
      <span class="filter-label">Type</span>
      <button class="filter-chip is-active" data-filter="ft" data-value="all" type="button">All</button>
      {distinctValues.map((v) => (
        <button class="filter-chip" data-filter="ft" data-value={v} type="button">{v}</button>
      ))}
    </div>
  </div>

  <p class="empty-state" hidden>No documents match the current filter.</p>

  <div id="content-search-results" class="content-results" hidden>
    <p class="content-results-status">Type to search inside document text…</p>
    <ol class="content-results-list"></ol>
  </div>

  <table class="doc-table">
    <thead>
      <tr>
        <th>Type</th>
        <th>Pages</th>
        <th>Bates ID / Title</th>
      </tr>
    </thead>
    <tbody>
      {docs.map((doc) => {
        const searchText = [
          doc.data.bates_id,
          doc.data.title,
          doc.data.doc_type,
          doc.data.format,
        ]
          .join(' ')
          .toLowerCase();
        return (
          <tr
            data-format-type={formatType(doc)}
            data-search-text={searchText}
          >
            <td class="type-cell">
              <span class={`format-badge format-${doc.data.format}`}>
                {doc.data.format === 'spreadsheet' ? 'Spreadsheet' : 'PDF'}
              </span>
              {doc.data.format === 'pdf' && (
                <span class="doc-type-suffix">({capitalize(doc.data.doc_type)})</span>
              )}
            </td>
            <td class="pages-cell">{doc.data.page_count ?? '—'}</td>
            <td>
              <a href={`/documents/${doc.data.bates_id}/`}>
                <code>{doc.data.bates_id}</code>
              </a>
              <div class="doc-title">{doc.data.title}</div>
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</BaseLayout>

<script>
  type Mode = 'filter' | 'content';

  const state: { ft: string; q: string; mode: Mode } = { ft: 'all', q: '', mode: 'filter' };
  const rows = document.querySelectorAll<HTMLTableRowElement>('.doc-table tbody tr');
  const table = document.querySelector<HTMLElement>('.doc-table');
  const empty = document.querySelector<HTMLElement>('.empty-state');
  const searchInput = document.getElementById('document-search') as HTMLInputElement | null;
  const contentResults = document.getElementById('content-search-results');
  const contentList = contentResults?.querySelector('.content-results-list');
  const contentStatus = contentResults?.querySelector('.content-results-status');
  const typeFilterRow = document.querySelector<HTMLElement>('[data-mode-only="filter"]');

  // Lazy-loaded Pagefind module — only fetched when the user switches to "Search inside documents".
  // The /* @vite-ignore */ comment tells Vite to leave the import alone (Pagefind doesn't exist
  // at Vite build time; the path is also rewritten to /unmasked/... by scripts/07-rewrite-paths-for-base.mjs).
  let pagefind: any = null;
  async function getPagefind() {
    if (pagefind) return pagefind;
    try {
      const pagefindUrl = '/pagefind/pagefind.js';
      pagefind = await import(/* @vite-ignore */ pagefindUrl);
      await pagefind.options({ excerptLength: 30 });
      return pagefind;
    } catch (err) {
      pagefind = null;
      return null;
    }
  }

  // ---- Filter mode (default): filter the rendered table by row text ----
  function applyFilterMode() {
    const q = state.q.toLowerCase().trim();
    let visible = 0;
    rows.forEach((row) => {
      const ft = row.dataset.formatType ?? '';
      const text = row.dataset.searchText ?? '';
      const typeOk = state.ft === 'all' || ft === state.ft;
      const queryOk = q === '' || text.includes(q);
      const isVisible = typeOk && queryOk;
      row.hidden = !isVisible;
      if (isVisible) visible++;
    });
    if (empty) empty.hidden = visible > 0;
  }

  // ---- Content mode: full-text search inside document pages via Pagefind ----
  let contentDebounce: number | null = null;
  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (ch) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch] as string));
  }

  async function applyContentMode() {
    if (!contentList || !contentStatus) return;
    const q = state.q.trim();
    if (q.length === 0) {
      contentStatus.textContent = 'Type to search inside document text…';
      (contentStatus as HTMLElement).hidden = false;
      contentList.innerHTML = '';
      return;
    }
    const pf = await getPagefind();
    if (!pf) {
      contentStatus.textContent = 'Search index not yet built. Try again after a build.';
      (contentStatus as HTMLElement).hidden = false;
      contentList.innerHTML = '';
      return;
    }
    contentStatus.textContent = `Searching for "${q}"…`;
    (contentStatus as HTMLElement).hidden = false;

    try {
      const search = await pf.search(q, { filters: { 'content-type': 'Document' } });
      const results = await Promise.all(search.results.slice(0, 30).map((r: any) => r.data()));
      if (results.length === 0) {
        contentStatus.textContent = `No matches inside any document for "${q}".`;
        contentList.innerHTML = '';
        return;
      }
      (contentStatus as HTMLElement).hidden = true;
      contentList.innerHTML = results
        .map((r: any) => {
          const title = r.meta?.title || r.url;
          return `
            <li class="content-result">
              <a href="${escapeHtml(r.url)}" class="content-result-link">${escapeHtml(title)}</a>
              <p class="content-result-excerpt">${r.excerpt}</p>
            </li>`;
        })
        .join('');
    } catch (err) {
      contentStatus.textContent = 'Search error — try a different query.';
      contentList.innerHTML = '';
    }
  }

  function applyMode() {
    if (state.mode === 'filter') {
      if (table) table.hidden = false;
      if (typeFilterRow) typeFilterRow.hidden = false;
      if (contentResults) contentResults.hidden = true;
      applyFilterMode();
    } else {
      if (table) table.hidden = true;
      if (typeFilterRow) typeFilterRow.hidden = true;
      if (contentResults) contentResults.hidden = false;
      if (empty) empty.hidden = true;
      applyContentMode();
    }
  }

  // Mode toggle (top-level chips with data-mode)
  document.querySelectorAll<HTMLButtonElement>('.filter-chip[data-mode]').forEach((btn) => {
    btn.addEventListener('click', () => {
      state.mode = (btn.dataset.mode as Mode) ?? 'filter';
      document.querySelectorAll<HTMLElement>('.filter-chip[data-mode]').forEach((b) => {
        b.classList.toggle('is-active', b.dataset.mode === state.mode);
      });
      applyMode();
    });
  });

  // Type filter chips (only meaningful in filter mode)
  document.querySelectorAll<HTMLButtonElement>('.filter-chip[data-filter]').forEach((btn) => {
    btn.addEventListener('click', () => {
      state.ft = btn.dataset.value!;
      document.querySelectorAll<HTMLElement>('.filter-chip[data-filter]').forEach((b) => {
        b.classList.toggle('is-active', b.dataset.value === state.ft);
      });
      if (state.mode === 'filter') applyFilterMode();
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      state.q = searchInput.value;
      if (state.mode === 'filter') {
        applyFilterMode();
      } else {
        // Debounce Pagefind queries
        if (contentDebounce !== null) window.clearTimeout(contentDebounce);
        contentDebounce = window.setTimeout(() => applyContentMode(), 150);
      }
    });
  }
</script>

<style>
  .archive-summary { font-family: var(--font-sans); color: var(--color-muted); margin-bottom: 1.5rem; }

  .filters {
    margin: 0 0 1.5rem;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .filter-row + .filter-row { margin-top: 0.6rem; }
  .search-label { flex: 1; }
  .search-input {
    width: 100%;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .search-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .filter-label {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    color: var(--color-muted);
    width: 4.5rem;
    flex-shrink: 0;
  }
  .filter-chip {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-family: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--color-text);
  }
  .filter-chip:hover { border-color: var(--color-accent); }
  .filter-chip.is-active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }
  .empty-state { color: var(--color-muted); font-style: italic; margin: 2rem 0; }

  .content-results { margin: 1rem 0 2rem; }
  .content-results-status { color: var(--color-muted); font-style: italic; font-family: var(--font-sans); }
  .content-results-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }
  .content-result {
    padding: 0.85rem 1rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }
  .content-result-link {
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }
  .content-result-link:hover { text-decoration: underline; }
  .content-result-excerpt {
    margin: 0.4rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.5;
  }
  .content-result-excerpt :global(mark) {
    background: rgba(15, 76, 92, 0.18);
    color: var(--color-text);
    padding: 0 0.15em;
    border-radius: 2px;
  }

  .doc-table { width: 100%; border-collapse: collapse; font-family: var(--font-sans); font-size: 0.95rem; }
  .doc-table th, .doc-table td { padding: 0.6rem 0.5rem; border-bottom: 1px solid var(--color-border); text-align: left; vertical-align: top; }
  .doc-table th { font-weight: 600; }

  .type-cell { white-space: nowrap; }
  .pages-cell { color: var(--color-muted); font-variant-numeric: tabular-nums; }
  .doc-title { color: var(--color-muted); font-size: 0.9rem; margin-top: 0.2rem; }
  .doc-type-suffix { color: var(--color-muted); font-size: 0.85rem; margin-left: 0.4rem; }

  .format-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .format-pdf {
    background: rgba(180, 30, 30, 0.1);
    color: #b41e1e;
    border: 1px solid rgba(180, 30, 30, 0.3);
  }
  .format-spreadsheet {
    background: rgba(30, 130, 70, 0.1);
    color: #1e8246;
    border: 1px solid rgba(30, 130, 70, 0.3);
  }
</style>
