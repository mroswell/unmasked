---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const terms = (await getCollection('glossary')).sort((a, b) => a.data.term.localeCompare(b.data.term));
const rendered = await Promise.all(
  terms.map(async (t) => ({
    term: t,
    ...(await render(t)),
    searchText: [t.data.term, ...t.data.aliases, t.data.short_def].join(' ').toLowerCase(),
  }))
);
---

<BaseLayout title="Glossary — Signals">
  <h1>Glossary</h1>
  <p class="lede">Definitions for terms used throughout the site. Five entries are formally defined in the source report's own glossary; the rest are editorial additions for non-experts.</p>

  <div class="filters" role="region" aria-label="Filter glossary">
    <div class="filter-row">
      <label class="search-label">
        <span class="visually-hidden">Search glossary</span>
        <input
          type="search"
          id="glossary-search"
          class="search-input"
          placeholder="Search glossary…"
          autocomplete="off"
        />
      </label>
    </div>
    <div class="filter-row">
      <span class="filter-label">Source</span>
      <button class="filter-chip is-active" data-filter="source" data-value="all" type="button">All</button>
      <button class="filter-chip" data-filter="source" data-value="original" type="button">Original report terms</button>
      <button class="filter-chip" data-filter="source" data-value="additional" type="button">Additional terms</button>
    </div>
  </div>

  <p class="empty-state" hidden>No glossary entries match the current search or filter.</p>

  <dl class="glossary">
    {rendered.map(({ term, Content, searchText }) => (
      <div
        class="entry"
        id={term.data.term}
        data-pagefind-body
        data-source={term.data.source}
        data-search-text={searchText}
      >
        <dt>{term.data.term}</dt>
        <dd>
          <p class="short-def">{term.data.short_def}</p>
          <Content />
        </dd>
      </div>
    ))}
  </dl>
</BaseLayout>

<script>
  const state: { source: string; q: string } = { source: 'all', q: '' };
  const entries = document.querySelectorAll<HTMLElement>('.entry');
  const empty = document.querySelector<HTMLElement>('.empty-state');
  const search = document.getElementById('glossary-search') as HTMLInputElement | null;

  function applyFilters() {
    const q = state.q.toLowerCase();
    let visible = 0;
    entries.forEach((el) => {
      const src = el.dataset.source ?? 'additional';
      const text = el.dataset.searchText ?? '';
      const sourceOk = state.source === 'all' || src === state.source;
      const queryOk = q === '' || text.includes(q);
      el.hidden = !(sourceOk && queryOk);
      if (sourceOk && queryOk) visible++;
    });
    if (empty) empty.hidden = visible > 0;
  }

  document.querySelectorAll<HTMLButtonElement>('.filter-chip').forEach((btn) => {
    btn.addEventListener('click', () => {
      const dim = btn.dataset.filter as 'source';
      const val = btn.dataset.value!;
      state[dim] = val;
      document.querySelectorAll<HTMLElement>(`.filter-chip[data-filter="${dim}"]`).forEach((b) => {
        b.classList.toggle('is-active', b.dataset.value === val);
      });
      applyFilters();
    });
  });

  if (search) {
    search.addEventListener('input', () => {
      state.q = search.value;
      applyFilters();
    });
  }
</script>

<style>
  .lede { color: var(--color-muted); max-width: var(--max-prose); }

  .filters {
    margin: 2rem 0 2rem;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .filter-row + .filter-row { margin-top: 0.6rem; }
  .filter-label {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    color: var(--color-muted);
    width: 4.5rem;
    flex-shrink: 0;
  }
  .search-label { flex: 1; }
  .search-input {
    width: 100%;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .search-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
  .filter-chip {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-family: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--color-text);
  }
  .filter-chip:hover { border-color: var(--color-accent); }
  .filter-chip.is-active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .empty-state {
    color: var(--color-muted);
    font-style: italic;
    margin: 2rem 0;
  }

  .glossary { display: grid; gap: 1.5rem; max-width: var(--max-prose); }
  .entry { padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .entry dt { font-family: var(--font-sans); font-weight: 600; font-size: 1.1rem; margin-bottom: 0.4rem; }
  .entry dd { margin: 0; }
  .short-def { font-style: italic; color: var(--color-muted); }
</style>
