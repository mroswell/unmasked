# Build output
dist/
.astro/
.cache/
*.tsbuildinfo

# Dependencies
node_modules/

# Environment
.env
.env.*

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Logs
*.log
npm-debug.log*

# Pipeline scratch (manifests committed; intermediates ignored)
split-proposals/*.tmp

# Document pipeline: raw downloads are derived from source URLs and not
# committed. Processed assets land in public/documents/ which IS committed.
# The manifest is small and is committed so the repo records exactly what
# was downloaded. We exclude individual downloaded files (not the directory
# itself) so !raw/manifest.json can re-include the manifest.
raw/*
!raw/manifest.json

# Local scratch
.tmp/

# Local-only attic — work-in-progress, backups, asset variants we
# want to keep on disk but never ship.
attic/

# Local-only interactive copies of plan checklists. The companion .md is
# committed; the .local.html mirror persists checked state in localStorage
# and is not meant to ship to the deploy or to GitHub.
*.local.html
